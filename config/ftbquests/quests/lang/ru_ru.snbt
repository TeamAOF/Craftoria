	quest.5A2F8167340FCA71.title: "unlocks/reagents/ash_flakes"
	quest.5A49CB40AC643E67.quest_desc: [
		"&bУлучшение: Батарея (Battery Upgrade)&f позволяет использовать &eэнергию&f вместо прочности. Палка получит возможность накапливать &eэнергию&f и использовать её для установки блоков."
		""
		"Используйте &bСтол кузнеца&f, чтобы применить это улучшение к вашей палке, используя &6медный блок&f в качестве материала."
	]
	quest.5A4ABDA1103A6C98.title: "unlocks/colored_saplings/light_blue_sapling"
	quest.5A4E9D4056DA2C67.quest_desc: ["&bЭлитный универсальный кабель&r может хранить &e409.6 kFE на кабель&r в сети, и каждый дополнительный кабель увеличивает общую скорость передачи сети на &e409.6 kFE/t&r."]
	quest.5A4E9D4056DA2C67.title: "Элитный универсальный кабель"
	quest.5A5583EA02C78372.quest_desc: [
		"Улучшенный дирижабль с огромным количеством места для хранения."
		""
		"Отлично подходит для перевозки кучи лута и руды домой."
		""
		"Он также идеально подходит для тех, кто жаждет кочевого образа жизни."
	]
	quest.5AB4D1D72EFD4428.quest_desc: ["&bИндукционный порт&r позволит вам взаимодействовать с вашей &9Индукционной матрицей&r. "]
	quest.5AB4D1D72EFD4428.title: "Индукционный порт"
