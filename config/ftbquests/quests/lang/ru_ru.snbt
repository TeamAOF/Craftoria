	quest.4EE5634E46F096D8.title: "milestones/reveal_malachite"
	quest.4EF9C36CED1EDDC4.quest_desc: ["&bПерья&r, &bКниги&r и &bЧерный краситель&r можно &6преобразовывать&r в &5Духовном огне (Spiritfire)&r, чтобы получить версии, более восприимчивые к работе с Духами."]
	quest.4EF9C36CED1EDDC4.quest_subtitle: "Правильный Обряд Правильного Писателя"
	quest.4EF9C36CED1EDDC4.title: "Оккультные письменные принадлежности"
	quest.4F076E5D6F0BED74.quest_desc: [
		"&bЗаклинание&r — это комбинация &bглифов&r."
		""
		"&bГлиф Формы (Form)&r: только 1 форма на &bзаклинание&r."
		"&8(некоторые инструменты чародея автоматически добавляют свою форму, поэтому вам не нужно добавлять форму в заклинание)&r"
		""
		"&bГлиф Усиления (Augment)&r: 1 или более на Форму/Эффект."
		""
		"&bГлиф Эффекта (Effect)&r: 1 или более на заклинание."
		""
		"&bСтоимость заклинания&r = &4стоимость без скидки&r - &2скидка&r."
		"- &4Стоимость без скидки&r: &5складывается&r из всех &bглифов&r."
		"- &2Скидка&r: от &bКольца Меньшей скидки (Ring of Lesser Discount)&r / &bКольца Большей скидки (Ring of Greater Discount)&r."
		""
		""
		"&8Проверьте &bСтраницу 2&8, если вы хотите убедиться, что стоимость заклинания — это просто сложение стоимости глифов заклинания (без умножения)."
		""
		"{@pagebreak}"
		"Проверьте github мода на наличие этих файлов :)"
		""
		"&8- SpellResolver.java вызывает getResolveCost() ⬇"
		""
		"&8- SpellContext.java вызывает getSpell() ⬇"
		""
		"&8- Spell.java содержит getCost(), который представляет собой просто цикл, проходящий через каждый глиф (AbstractSpellPart) и получающий его стоимость"
	]
	quest.4F076E5D6F0BED74.quest_subtitle: "Основы заклинаний"
