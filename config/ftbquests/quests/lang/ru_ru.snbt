	quest.4EC1818FF036CE0E.title: "unlocks/glowblocks/gray_glowblock"
	quest.4EC894E7808440AC.quest_desc: [
		"&bРасширенный поставщик шаблонов&r вмещает в четыре раза больше шаблонов по сравнению с обычным."
		""
		"&bРасширенный молекулярный сборщик&r выполняет 8 заданий крафта одновременно со скоростью в 2 раза выше обычного, что в сумме дает 16-кратное увеличение скорости крафта."
	]
	quest.4EC894E7808440AC.quest_subtitle: "В четыре раза больше Шаблонов, в 16 раз выше Скорость"
	quest.4ED1400E2AAAAAE1.quest_subtitle: "Поймайте &a10&r рыб в общей сложности."
