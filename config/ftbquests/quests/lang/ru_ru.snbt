	file.0000000000000001.title: "&lCraftoria"
	quest.000F7897FF9ED7DC.quest_desc: ["Есть &a4 стадии&f роста, прямо как у &bДруз истинного кварца&f. На &aпервых трёх стадиях&f вы будете получать &bЭнтро-пыль&f, но на &aчетвёртой стадии&f сможете получить &bЭнтропированные кристаллы&f."]
	quest.0012F8780D9172DE.quest_subtitle: "Можно найти с помощью Ока Бездны"
	quest.0012F8780D9172DE.title: "&5Левиафан"
	quest.00237AB9C48C8A9B.quest_desc: ["&bКонденсатор материи&f позволит вам &6создавать &bШарики материи&f для &bПокрасочного пистолета&f, а также &6создавать &bСингулярности&f за счет поглощения &aпредметов&f."]
	quest.002410CF49E1E14E.quest_desc: ["Объедините с &bКомпонентами хранения FE&f, чтобы хранить &4энергию&f."]
	quest.0035439F73199781.quest_desc: ["Я думал, что &bсталь&f — это &bжелезо и углерод&f, а эта просто заряжена, и даже не выкована."]
	quest.0035439F73199781.quest_subtitle: "И они называют это \"сталью\""
	quest.0035439F73199781.title: "&eЗаряженная сталь"
	quest.003AC28EAB72F0E6.title: "unlocks/equipment/early_elytra"
	quest.003C38C78609709B.quest_desc: ["Создаваемый в &bВысекателе&f, &bНакопительный пресс&f используется со &bСлитками небесного камня&f для производства &bНакопительных контуров&f."]
	quest.006DFA2A9D28D01B.title: "unlocks/blocks/fabrication_chest"
	quest.0075009DEEA010B7.quest_desc: [
		"Готовьтесь к войне..."
		"...и пригласите друзей!"
		""
