	quest.73CCDC1E2A35AA3E.title: "unlocks/glowblocks/light_gray_glowblock"
	quest.73D8B9B4285D55E1.title: "unlocks/food/jaramel"
	quest.73DF4B8186890BFE.quest_desc: [
		"- &bРеле истока: Сборщик (Source Relay: Collector)&r"
		"Берет исток из всего, &4кроме добавленного в белый список (whitelist)&r."
		"&8(всё еще нужно указать в белом списке, куда его отправлять)"
		""
		"- &bРеле истока: Раздатчик (Source Relay: Depositor)&r"
		"Отправляет исток во всё, &4кроме добавленного в белый список&r."
		"&8(всё еще нужно указать в белом списке, откуда его брать)"
		""
		"- &bРеле истока: Исказитель (Source Relay: Warper)&r"
		"Бесконечное расстояние передачи."
		"&8(после 30 блоков есть шанс &4потерять &8исток)"
		""
		"- &bРеле истока: Разделитель (Source Relay: Splitter)&r"
		"Берет исток из &9более чем 1 источника&r, отправляет в &9более чем 1 приемник&r."
		"&8(оно особенное, имеет более высокую скорость передачи)"
		""
		"- Используйте &bЖезл Доминиона&r для привязки."
		"&8(чтобы сбросить настройки, нажмите &6Shift + ПКМ&r &8Жезлом Доминиона)"
	]
