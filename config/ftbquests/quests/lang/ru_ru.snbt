	quest.5BBB0BDD45F6FFC0.quest_desc: ["Дьявол дает &bсопротивление огню&r."]
	quest.5BBB0BDD45F6FFC0.quest_subtitle: "Управляемое пекло"
	quest.5BBD4DE3D735DFEA.title: "unlocks/ampoules/raw_azurite_ampoule"
	quest.5BCED97AA55DE2E3.quest_desc: [
		"- По умолчанию: "
		"&8На себя (Self) -> Прыжок (Leap) -> Усиление (Amplify)"
		""
		"- Более длинный прыжок "
		"&8На себя (Self) -> Прыжок (Leap) -> Усиление (Amplify) -> Усиление (Amplify)"
		""
		""
		"&8Вы можете добавить &5Отскок (Bounce) &8в конце, если беспокоитесь об уроне от падения."
		"&8С зачарованием &6Невесомость (Feather Falling) &8вы можете произнести это заклинание горизонтально перед касанием земли. (урон от падения будет ничтожным)"
	]
	quest.5BCED97AA55DE2E3.quest_subtitle: "Пример Заклинания"
	quest.5BCED97AA55DE2E3.title: "Передвижение"
	quest.5BDE55C11519F7F7.quest_desc: [
		"&bКамера очистки (Purification Chamber)&r позволяет вам перерабатывать различные &9сырые руды&r и &eосколки&r в &cкомки (clumps)&r, используя &7кислород&r. "
		""
		"Этот механизм — первый этап к &a300%&r переработке руды. "
	]
	quest.5BDE55C11519F7F7.title: "Камера очистки"
	quest.5BDEC0D157A43D9E.quest_desc: ["&5Пурпурный&r Мел часто используется в ритуалах, которые привязывают духов к объектам."]
	quest.5BDEC0D157A43D9E.quest_subtitle: "Наполнение"
