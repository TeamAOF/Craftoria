	quest.5A2B3D4660D8D741.quest_desc: ["Для этого ресурса требуются &bизумруды&f, и он необходим для создания &6Одухотворенных (Spirited) улучшений"]
	quest.5A2B3D4660D8D741.quest_subtitle: "Я думал, что Духи синие"
