	quest.5C30DE7BDF46FD66.title: "unlocks/equipment/oblivion_pickaxe"
	quest.5C4A9D72986122D9.title: "hidden/collect_vanilla/glow_lichen"
	quest.5C56A0938613CBC0.quest_desc: [
		"Этот металл можно &6найти&r в &bНезере&r, замаскированный под Незеррак."
		""
		"&6Взгляд&r через &bТретий Глаз (Third Eye)&r раскрывает его истинную форму. Возможно, вам стоит взять с собой &bЛозоходческий жезл (Divination Rod)&r."
	]
	quest.5C56A0938613CBC0.quest_subtitle: "Как ты это произносишь?"
	quest.5C7FA95F0DBB84FE.title: "unlocks/enchantments/vanilla_swift_sneak"
	quest.5C82C92D1F366C04.quest_desc: ["&bСовершенная плавильная фабрика&r может выполнять до &a9&r процессов переплавки одновременно и оснащена такой же функцией \"&eАвтосортировки&r\"."]
	quest.5C82C92D1F366C04.title: "Совершенная плавильная фабрика"
	quest.5C8D7BD3DA61109F.quest_desc: [
		"  Вы добрались до электрической версии &bКарьера&r! Он позволяет добывать руды еще быстрее, чем раньше, &oи&r предоставляет больше вариантов буров."
		""
		"  &6Теперь вы сможете использовать &bСтальные&r&6, &bЗолотые&r&6, &bИз нержавеющей стали&r&6 и &bТитановые Буры&r, чтобы завершить автоматизацию добычи руды и воистину исполнить мое обещание о том, что вам больше никогда не придется копать руду самому!"
		""
		"  Структура &oабсолютно&r такая же, как у &bПарового карьера&r, за исключением того, что вместо &bЛюка ввода жидкости&r нужен &bЛюк ввода энергии&r. &6Убедитесь, что к этому моменту вы уже автоматизировали свои &bБронзовые Буры&r&r, иначе поддерживать работу карьеров будет мучением."
	]
	quest.5C8D7BD3DA61109F.quest_subtitle: "Ресурсы делают ВЖЖЖ!"
	quest.5C8D7BD3DA61109F.title: "Электрический карьер"
	quest.5C98D9127F4CEB74.quest_desc: [
		"Существует несколько видов &bСоли&r, и каждый из них в конечном итоге используется для создания &6различных ресурсов&r."
		""
		"Некоторые Соли могут быть &6кальцинированы&r повторно, превращаясь в другие виды."
	]
	quest.5C98D9127F4CEB74.quest_subtitle: "Не та, что на столе"
	quest.5C98D9127F4CEB74.title: "Алхимические Соли"
	quest.5CA7CF7DAEB85719.title: "unlocks/gemstone_lights/onyx"
	quest.5CD12382792FA310.quest_desc: [
