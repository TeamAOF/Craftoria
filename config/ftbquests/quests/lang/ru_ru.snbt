	quest.292875386D7B9981.title: "&aУранит"
	quest.293C22FC12999302.title: "Лунные ягоды"
	quest.294687276C7FEA05.title: "hidden/collect_vanilla/wither_skeleton_skull"
	quest.294DAE3110CB6162.title: "milestones/unlock_complex_reagents"
	quest.294F8A492B54F540.title: "hidden/status_effects/magic_annulation"
	quest.2976D5A533FDEE8F.quest_subtitle: "Толкай и тяни дальше"
	quest.299CBEA2571FD97A.quest_subtitle: "&bСиние кристаллы"
	quest.299CBEA2571FD97A.title: "&bНиотический кристалл"
	quest.29A942B4C3E9A502.quest_desc: [
		"&6Срубает&r даже самые высокие &bдеревья&r, или &6разрезает&r множество &bвещей&r на... ещё больше &bвещей&r."
		""
		"Так как для &bМеханической пилы&r существует множество рецептов с различными возможными входами, вам захочется &6зафиксировать&r рецепт, &6ударив&r по её верхней части примером желаемого результата."
	]
	quest.29A942B4C3E9A502.quest_subtitle: "Не Сток, Эйткен и Уотерман"
	quest.29AC06B27D6A53C5.quest_desc: [
		"Запрограммированный &bДрон&r, который собирает &bпредметы&r в области &e17x17x17&r &7(до установки улучшений дальности)&r с центром в той точке, откуда он был выпущен. "
		""
		"Этот &bДрон&r имеет два основных &3режима&r в зависимости от того, где он выпущен по отношению к его инвентарю сброса:"
		""
		"- Выпуск поверх &9инвентаря&r заставит &bДрона&r &6отфильтровывать&r то, что он собирает, чтобы оно соответствовало только тем &bпредметам&r, которые находились внутри &9инвентаря&r в момент выпуска."
		""
		"- Выпуск на землю рядом с &9инвентарем&r прикажет &bДрону&r &6собирать&r любые &bпредметы&r в своей зоне."
	]
	quest.29AC32175F2F592D.title: "unlocks/items/heavy_core"
	quest.29AD1060C129C86F.quest_subtitle: "Поймайте &a50&r рыб в общей сложности."
	quest.29B59876D04A3772.quest_desc: [
		"Это устройство &6спавнит&r &2мобов&r используя &7давление&r, обходя ограничения по &eуровню освещения&r и поддерживая &4управление редстоуном&r. "
		""
		"Для работы ему требуется &bЯдро спавнера&r. "
		""
		"Имейте в виду, что &7частично пустое&r &bЯдро спавнера&r приведет к &cпониженной эффективности&r."
	]
	quest.29BA27F8C10E205F.title: "unlocks/trinkets/pigment_palette"
	quest.29BFCE71A758AF8D.title: "mod_integration/mythicmetals/unlock_banglum"
	quest.29CFD0E01542A93D.quest_desc: [
		"С &bКартой квантового моста&f вы можете получить доступ к своей &bМЭ Системе&f из любой точки мира. Вам понадобится установить &bКвантовое кольцо&f со &bСвязанной сингулярностью&b внутри и поместить вторую сингулярность в ваш &bБеспроводной терминал&f, предварительно вставив в него &bКарту квантового моста&f."
		""
		"Убедитесь, что чанк с &bКвантовым кольцом&f прогружается (chunk loaded), иначе оно не будет работать."
	]
	quest.29D05998ADC8ACF5.quest_desc: ["  Супер-продвинутый процессор, позволяющий довести возможности оверклокинга вашего механизма до предела, и вскоре... для чего-то немного более &cЯдерного&r."]
	quest.29D05998ADC8ACF5.title: "Вычислительное устройство"
	quest.29DB22895AB3029D.title: "unlocks/enchantments/disarming"
	quest.29DE74B144E0A85F.quest_desc: ["&6Оранжевый&r Мел идеально подходит для призыва Афритов, хотя он и не дает контроля над ними."]
	quest.29DE74B144E0A85F.quest_subtitle: "Пикантный"
	quest.29E3DC274AF5DAFA.quest_desc: [
		"  &bГаечный ключ из феррикора&r — это... гаечный ключ."
		""
		"  При строительстве он может &6вращать&r блоки — очень удобно."
		""
		"  Опробуйте его на всех ваших любимых технических блоках, которые взаимодействуют с гаечными ключами."
		""
		"{image:justdirethings:item/ferricore_wrench width:100 height:100 align:center fit:true}"
	]
	quest.29E3DC274AF5DAFA.quest_subtitle: "Никаких обезьяньих дел (Monkey Business)"
	quest.29E6ED5067027F08.quest_desc: [
		"- Может партиями выполнять &6рецепты&r любого одноблочного &eэлектрического&r &bмеханизма&r для крафта, предоставленного ему."
		""
		"- Размер партии определяется количеством предоставленных ему &bмеханизмов&r."
		""
		"- Вставьте &eэлектрические&r механизмы для крафта, чтобы они работали &6параллельно&r."
	]
	quest.29EB6FA48EDBE556.quest_desc: ["&7Светло-серый&r Мел служит улучшенным базовым мелом по сравнению с Белым, лучше стабилизируя созданные им пентакли."]
	quest.29EB6FA48EDBE556.quest_subtitle: "Второй фундамент"
	quest.29FD28EE169FB417.title: "hidden/visit_dd_biomes/crystal_gardens"
	quest.2A08F71925AE775E.quest_desc: ["В смысле... всё сказано прямо в названии."]
	quest.2A1319D8CFE3653B.quest_desc: [
		"По умолчанию объем хранилища у Привода не самый большой."
		""
		"Вы можете решить эту проблему, используя &bСтабилизаторы&r. Они дополнительно &6стабилизируют&r связь Привода с измерением хранения, позволяя ему &6вмещать всё больше&r и больше."
	]
	quest.2A1319D8CFE3653B.quest_subtitle: "Сюда можно было бы поместить дом..."
	quest.2A1D9C6699BF8A21.quest_desc: [
		"Аддоны Ars Nouveau + Farmers Delight."
		""
		"&8Для получения дополнительной информации, пожалуйста, загляните в книгу &5Ars Nouveau&8."
		"&8- Больше еды из Ars."
		"&8- Больше эффектов баффов."
		"&8- Дригми, использующие Ножи."
		"&8- Автоматизация Разделочной доски с помощью заклинаний."
		"&8- И многое другое..."
		""
		""
		"&4ПРИМЕЧАНИЕ&r: прочность ножа будет расходоваться."
	]
	quest.2A1D9C6699BF8A21.quest_subtitle: "Farmers Delight"
	quest.2A1D9C6699BF8A21.title: "Аддон Ars Delight"
	quest.2A2E1C7C34C9A4AA.quest_desc: ["Гаджет разрушения (Destruction Gadget) убирает блоки и уничтожает их."]
	quest.2A4193454BA15A9E.title: "Дуриан"
	quest.2A4F8CE1B4627285.title: "unlocks/items/bottle_of_fading_essence"
	quest.2A5CD188C06D7F3C.quest_desc: [
		"- &bАппарат зачарования&r"
		"Нажмите &6ПКМ&r по Аппарату зачарования &6пустой рукой&r."
		"Он подсветит все &bПьедесталы&r в радиусе действия."
		""
		"- &bКамера наполнения (Imbuement Chamber)&r"
		"Нажмите &6ПКМ&r по Камере наполнения &bпредметом&r, чтобы подсветить пьедесталы. "
		"&8(не используйте аметист/лазурит)&r"
		""
		"- &bКотёл Викси&r, &bАппарат зачарования Викси&r"
		"&8(не будут подсвечиваться, но их &9радиус действия &8&2такой же&8, как у &bКамеры наполнения&8)"
	]
	quest.2A5CD188C06D7F3C.quest_subtitle: "Как узнать, в радиусе ли он"
	quest.2A5CD188C06D7F3C.title: "Как узнать, в радиусе ли он?"
	quest.2A5F7EE33089284E.title: "unlocks/enchantments/clovers_favor"
	quest.2A68AB7D1EDD44BD.quest_desc: [
		"&bСтруктурное стекло&r — это блок, который можно использовать почти в любом &eмногоблочном механизме&r в качестве прозрачного блока."
		" "
		"Я рекомендую попробовать использовать его для стен &bДинамического резервуара (Dynamic Tank)&r, в то время как края будут состоять из твердых блоков динамического резервуара."
	]
	quest.2A68AB7D1EDD44BD.title: "Структурное стекло"
	quest.2A77A976BEAD8BF7.title: "unlocks/colored_lamps/any_colored_lamp"
	quest.2AA988AB38DFD978.title: "unlocks/equipment/bedrock_tools"
	quest.2AABAC42E7880AA1.quest_desc: [
		"&bЭлитная труба высокого давления&r добавит &9256,000 мБ/т на трубу&r к общей емкости и базовой пропускной способности сети труб. "
		""
		"Каждая \"&aвытягивающая&r\" труба ограничена &964,000 мБ/т&r."
	]
	quest.2AABAC42E7880AA1.title: "Элитная труба высокого давления"
	quest.2AB5183A0BD8D387.quest_desc: [
		"Используется для многократного увеличения скорости крафта без затрат пространства"
		""
		"Вмещает до 1024 сопроцессоров"
	]
	quest.2AB5183A0BD8D387.title: "Многоядерный ускоритель крафта"
	quest.2ABCACEBACE7A37D.title: "Менриловые ягоды"
	quest.2AC6E9EFC6D1D83D.title: "unlocks/items/phantom_frames"
	quest.2ACF8F5EFD3C4AF7.title: "Ботинки"
	quest.2ADDD30536A7FF68.quest_desc: ["&bРеакторное стекло&r — это &3супер-улучшенный прозрачный материал&r, который можно использовать для центральных стенок &bТермоядерного реактора&r. Всем нравится &6наблюдать&r за красивыми цветами (которые могут, а могут и не &4распылить&r вас на атомы)."]
	quest.2AF493802C789D70.title: "unlocks/ampoules/pure_malachite_ampoule"
	quest.2B0E19B0B1A65682.title: "unlocks/enchantments/vanilla_trial_treasure"
	quest.2B1717F5D6E20B79.quest_desc: [
		"  Имея &bЭлектролизёр&r, достаточное количество времени и энергии, а также вашу свежесозданную &bСингулярность&r, вы можете извлекать огромное количество энергии посредством &bКвантового излучения Хокинга&r в форме &bУниверсально применимой материи&r, также известной просто как &dUU Материя&r."
		""
		"  Это, по сути, сама &oткань&r &9вселенной&r."
	]
	quest.2B1717F5D6E20B79.title: "Ведро UU Материи"
	quest.2B1AEE4E402828BF.title: "unlocks/malachite/glass_crest_ultra_greatsword"
	quest.2B1C36C0FCB9E220.title: "unlocks/trinkets/fanciful_belt"
	quest.2B2D3B338662F02C.quest_desc: ["Этот особенно чистый вариант золота используется для &6изменения&r &aтира&r &bСеры&r."]
	quest.2B3B96DDFE5D3ACA.quest_desc: ["Используя &bКорпуса бойлера&r, вы можете создать &bТермоэлектрический бойлер&r для &6генерации&r дополнительного &7пара&r за счет &cвнешнего тепла&r, в том числе от &9Перегретого жидкого натрия&r из активного &bРеактора деления&r."]
	quest.2B3B96DDFE5D3ACA.title: "Корпус бойлера"
	quest.2B41DC5E4D733C9C.quest_subtitle: "Выпадает врат Испытаний Пробуждения. "
	quest.2B46EC21AC22752D.title: "unlocks/enchantments/vanilla_damage"
	quest.2B482168EC0C6EB8.quest_subtitle: "Стелс в весёлом стиле."
	quest.2B4BFD88DF1A934D.quest_desc: ["  Он весит в треть меньше стали, но при этом пластичен и легко поддается ковке. Он создается путем нагревания и извлечения его из &bБоксита&r. Вы можете сделать это в вашей недавно построенной &bEBF&r. &6Обязательно автоматизируйте производство &bАлюминия&r, так как в итоге вы будете использовать ОЧЕНЬ МНОГО этого металла&r."]
	quest.2B4BFD88DF1A934D.quest_subtitle: "Всё будет Ал-юминиево, ясно?"
	quest.2B4BFD88DF1A934D.title: "Алюминий"
	quest.2B64E0CC82E29E29.title: "hidden/discover_rock_crystal"
	quest.2B85BFD9DAB96DA2.title: "milestones/unlock_conflicted_enchanting_with_enchanter"
	quest.2B8DFC9987083AF7.quest_desc: [
		"Этот механизм &6производит&r &7Сжатый воздух&r. "
		""
		"Для его работы &6поместите&r любой &8твердотопливный&r предмет, который может &cгореть&r в &8Печи&r, в слот для топлива. "
		""
		"Обратите внимание, что &7вёдра с топливом&r не подходят; для &7жидкого топлива&r используйте &bЖидкостный компрессор&r."
	]
	quest.2B93E05DF355F1ED.title: "hidden/visit_dd_biomes/black_langast"
	quest.2BA177DF896F212B.title: "mod_integration/the_bumblezone/light_blue_calming"
	quest.2BB266022C8BFC8C.quest_desc: ["Используется как корпус для размещения &bМЕГА-компонента хранения&f."]
	quest.2BBC228E24D5EF05.quest_desc: [
		"&bВарп-портал&r — это еще одно решение для перемещения из точки А в точку Б. "
		"Один раз настроив, вы сможете пользоваться им всегда."
		""
		"&l1. Информация&r"
		"- &bВарп-свиток&r"
		"&8Постоянный портал в пределах одного измерения"
		""
		"- &bСтабилизированный Варп-свиток&r"
		"&8Постоянный межпространственный портал"
		""
		"- &lПортал односторонний&r"
		"&8он не создаст ответный портал в точке, которую вы задали в свитке"
		""
		"- &9Размер&r \\& &6Ориентация&r"
		"&8+ Материал рамки: &bКамень истока (Sourcestone)&r &8(или его варианты)"
		""
		"&8+ Минимум &91x1 &8пустого пространства внутри &bрамки &8(угловые блоки могут быть любыми)"
		"&8(минимальный размер рамки будет &93x3 &8(пустая в центре))"
		""
		"&8+ Может располагаться &6горизонтально &8(как портал в Энд) или &6вертикально &8(как портал в Незер)"
		""
		"&l2. Как создать?&r"
		"- Постройте &bрамку&r. (подобно порталу в Энд или Незер)"
		"- Поставьте рядом &9ПОЛНУЮ&r банку истока."
		"- Бросьте внутрь &bВарп-свиток&r / &bСтабилизированный Варп-свиток&r."
		""
		"&l3. Как сломать?&r"
		"- &6Сломайте&r любой блок рамки."
		""
		""
		"&4ПРИМЕЧАНИЕ&r: после создания ему больше не потребуется &5исток&r для работы."
		"&4ПРИМЕЧАНИЕ 2&r: повторюсь, блоки по углам рамки не обязательны."
	]
	quest.2BBC228E24D5EF05.quest_subtitle: "Несколько баз?"
	quest.2BBC228E24D5EF05.title: "Варп-портал"
	quest.2BC64E1EB1BCE14D.quest_desc: [
		"  &bБур из нержавеющей стали&r — это новый бур, который &6можно использовать &oкак&r&6 в &bКарьере&r, &6так и в &bНефтедобывающей вышке&r."
		""
		"  В карьере вы добудете новые редкие ресурсы, которые будут чрезвычайно полезны в будущем."
		""
		"  В буровой вышке вы сможете выкачивать &bСланцевую нефть&r, которую можно дистиллировать в &bГелий&r, &bСернистую сырую нефть&r и &bСернистую нафту (Sulfuric Naphtha)&r."
	]
	quest.2BC64E1EB1BCE14D.title: "Бур из нержавеющей стали"
	quest.2BC7AADCA8E844DD.title: "unlocks/colored_saplings/white_sapling"
	quest.2BDE797C32E308D3.quest_desc: [
		"&bСовершенная труба высокого давления&r добавит &91,024,000 мБ/т на трубу&r к общей емкости и базовой пропускной способности сети труб. "
		""
		"Каждая \"&aвытягивающая&r\" труба ограничена &9256,000 мБ/т&r."
	]
	quest.2BDE797C32E308D3.title: "Совершенная труба высокого давления"
	quest.2BF12A2184F8E99D.title: "Хурма"
	quest.2BF835F8F73E8F06.quest_desc: [
		"Я понимаю, копать руду — это скука. "
		""
		"Но вам больше не придется &6копать каждый блок&r по отдельности (&cесли только вы не сумасшедший&r). "
		""
		"&3По умолчанию&r кнопка с тильдой (~), рядом с цифрой \"&61&r\" — это та &aкнопка&r, которую вам нужно удерживать, пока вы &6ломаете блок&r. "
		""
		"Для активации Ultimine требуется &8инструмент&r."
		""
		"Он добудет до &664&r &bблоков&r этого типа, которые прилегают друг к другу. "
		""
		"&6Удерживая&r эту кнопку и &6прокручивая колёсико мыши&r, вы можете менять &aрежимы&r. "
		""
		"Они отображаются в верхнем левом углу экрана, так что поглядывайте туда. "
		""
		"Я позволю вам поэкспериментировать с &aрежимами&r, &cтолько ничего не сломайте лишнего&r!"
	]
	quest.2BF835F8F73E8F06.quest_subtitle: "Копаем, копаем яму!"
	quest.2BF835F8F73E8F06.title: "&cПрочь, жила!"
	quest.2C323F602F7ED630.title: "unlocks/food/honey"
	quest.2C42A6E79A5242F0.quest_subtitle: "Используются для ловли рыб, обитающих в определенных биомах."
	quest.2C42A6E79A5242F0.title: "Наживка"
	quest.2C4CA092A557205E.quest_desc: [
		"  1985-й год звонил из 2015-го, он хочет вернуть свою антигравитационную технологию!"
		""
		"  &bГрави-нагрудник&r использует сверхпроводящий кабель, намотанный вокруг платинового сердечника, чтобы создавать вокруг игрока поле, изменяющее пространство и инвертирующее гравитационное притяжение настолько, чтобы оторвать игрока от земли."
		""
		"  Он управляется путем регулирования мощности, подаваемой на катушки, направленные в разные стороны. Поскольку он воздействует на гравитационное поле, вы не получите урон от падения, хотя из-за хрупкости и сложности компонентов, из которых состоит &bГрави-нагрудник&r, он не защитит вас от других видов урона."
		""
		"  &6Для работы он использует EU (и очень много)&r, поэтому его можно зарядить, кликнув ПКМ по блоку, который может отдавать энергию."
	]
	quest.2C4CA092A557205E.title: "Грави-нагрудник"
	quest.2C4E81B5F427DECD.quest_desc: ["Мод Sushi Go Crafting добавляет несколько культур \\& материалов для приготовления... вы угадали, суши!"]
	quest.2C522C316A676B7D.title: "unlocks/gemstone_lights/citrine"
	quest.2C66FFA15364FDB2.title: "triggers/hints/azurite_page0"
	quest.2C67C22D74F097A3.quest_desc: [
		"Некоторые примечательные &bритуалы&r:"
		""
		"- &bСкрижаль привязки&r"
		"&8Превращает особых мобов в фамильяров."
		""
		"- &bСкрижаль удержания&r"
		"&8Ловит сущности (предмет/моб) в Банку удержания."
		""
		"- &bСкрижаль вызова&r"
		"&8Вызывает рейд, если использовать на \"жителя\"."
		""
		"- &bСкрижаль полета&r"
		"&8Творческий полет в радиусе около 60 блоков."
		""
		"- &bСкрижаль призыва вилдена:&r"
		"&8Призывает мобов-вилденов. (Или босса Химеру, если ритуал усилен)"
	]
	quest.2C67C22D74F097A3.quest_subtitle: "Этот квест для перфекционистов"
	quest.2C67C22D74F097A3.title: "Пурпурные скрижали"
	quest.2C78397EB8EEB67A.title: "hidden/collect_vanilla/nautilus_shell"
	quest.2C7BABC76D6DE355.title: "unlocks/glowblocks/purple_glowblock"
	quest.2C8902E340DD210E.title: "hidden/collect_pigment/green"
	quest.2C92B957A5E8646F.quest_desc: ["&bПустой шаблон&f используется для &6автоматизации&f рецептов крафта. Вы должны &6закодировать&f &bПустой шаблон&f в &bКодировщике шаблонов&f, а затем поместить его в &bПоставщик шаблонов&f."]
	quest.2CAEBBC8E99FA920.title: "triggers/hints/amethyst_page0"
	quest.2CB005B413D2B889.quest_desc: [
		"Да, вы можете быть моделью! "
		""
		"Используя &bСтол трансмогрификации&r, вы можете &6замаскировать&r &oлюбой&r &7предмет&r, &7блок&r или &7броню&r подо что угодно другое, при условии, что это останется &7предметом&r. "
		""
		"Хотите носить блок на голове? "
		"Делайте это! "
		""
		"Замаскировать самый сильный меч под печеньку? "
		"Почему бы и нет? "
		""
		"Комбинации бесконечны. "
		""
		"&9Демонстрируйте &oСвой Стиль&r."
	]
	quest.2CB005B413D2B889.quest_subtitle: "Зажигай, Королева!"
	quest.2CB005B413D2B889.title: "&cБудьте &aИконой &9Стиля&8!"
	quest.2CC5D8F1BDFC8A36.title: "triggers/hints/clover_page1"
	quest.2CE7390F7567D9E2.quest_desc: [
		"  &bПростой&r:"
		"    • Работают парами"
		"    • &6Меняют местами&r &bблоки&r (вкл. &bвоздух)&r"
		"    • &3Сущности&r &6телепортируются&r (поодиночке)"
		"    • Настройки &eчувствительности&r к &4редстоуну&r"
		""
		"  &bПродвинутый&r:"
		"    • Добавляет &6фильтрацию&r и &3смещение зоны действия (AOE)&r"
		"    • Требует &cэнергию&r"
		""
		""
		"{image:justdirethings:block/blockswappert2_side width:100 height:100 align:center}"
	]
	quest.2CE7390F7567D9E2.quest_subtitle: "Порталы в виде механизма"
	quest.2D051675EBBAE4ED.title: "unlocks/food/verdigris_wine"
	quest.2D12653352AAD2E2.title: "unlocks/equipment/dragonrending_pickaxe"
	quest.2D15A536403974E2.title: "hidden/interact_with_dragonrot"
	quest.2D2A4E52CF79C196.title: "unlocks/equipment/knotted_sword"
	quest.2D4170B5AD28DCBF.quest_desc: [
		"  Лучший одноблочный &bДизельный генератор&r, который вы можете создать. &6Он будет выдавать до 1024 EU/t&r из любой из множества жидкостей, перечисленных в вашем EMI."
		""
		"  Однако это не лучший генератор, работающий на жидком топливе. Существует такая вещь, как &bБольшой дизельный генератор&r, который потребует &bУлучшенных продвинутых корпусов механизмов (Highly Advanced Machine Hulls)&r; хотя это того стоит, когда вы услышите, что &6он будет генерировать до 16,384 EU/t&r!"
	]
	quest.2D4170B5AD28DCBF.title: "Дизельный генератор высокого напряжения (HV)"
	quest.2D4564F6C18AE96B.quest_desc: ["&bПродвинутая логистическая транспортная труба&r может втягивать в транспортную сеть по &a32 предмета в секунду&r и передавать их со скоростью &a2.0 метра в секунду&r."]
	quest.2D4564F6C18AE96B.title: "Продвинутая логистическая транспортная труба"
	quest.2D4CD4E32D1AF5AE.title: "unlocks/reagents/pure_resources"
	quest.2D5A0399B7FFA5DB.quest_desc: ["Ктулху позволяет вам &6дышать&r &bпод водой&r."]
	quest.2D5A0399B7FFA5DB.quest_subtitle: "Приюти жуткий ужас уже сегодня"
	quest.2D7A0E39E2FB8EF8.title: "unlocks/blocks/fusion_shrine"
	quest.2D8FB52E37D7D96C.quest_desc: ["Спавнеру не нужен игрок поблизости."]
	quest.2D8FB52E37D7D96C.quest_subtitle: "+ Игнорирует игроков"
	quest.2D9B4753070575FD.title: "unlocks/blocks/titration_barrel"
	quest.2DAE44549D0FDD55.quest_desc: [
		"&bБанки истока&r используются для хранения &5истока&r."
		""
		"- Каждая банка истока может хранить &510000 истока&r. "
		""
		""
		"&8(чтобы просмотреть точное значение вместо процентов, используйте мод &bintegrated dynamics&r&8)"
	]
	quest.2DAE44549D0FDD55.quest_subtitle: "Хранилище истока"
	quest.2DD08FC93F6ED0EF.title: "unlocks/blocks/crystal_apothecary"
	quest.2DDF658C99BE5911.title: "unlocks/reagents/onyx_powder"
	quest.2DFC8E60A89E4B31.title: "unlocks/blocks/item_bowl"
	quest.2E0837E85AD433EC.quest_subtitle: "Булочки с корицей лучше"
	quest.2E192A8302EA6B38.title: "unlocks/food/sawblade_holly_titration"
	quest.2E1EB12F3D9B315E.quest_desc: [
		"Некоторые примечательные &bритуалы&r:"
		""
		"- &bСкрижаль сотворения острова: Пустыня&r"
		"&8+ Превращает &9радиус &8вокруг себя в &bдругой биом&8 (в какой? Проверьте описание скрижали)"
		"&8+ Блоки воды/воздуха будут &4заменены."
		"&8+ Требует &5исток &8во время работы. (после завершения он больше не нужен)"
		""
		"- &bСкрижаль расщепления&r"
		"&8Примечание создателя квеста: оно того не стоит."
		"&8+ Вам не только нужен исток для работы, но и опыт выпадает в виде предметов. "
		"&8+ Использовать его (по стаку за раз) — та еще морока."
	]
	quest.2E1EB12F3D9B315E.quest_subtitle: "Этот квест для перфекционистов"
	quest.2E1EB12F3D9B315E.title: "Красные скрижали"
	quest.2E50F969D8AE49B2.quest_desc: ["Каждая &bЭлитная индукционная ячейка&r, добавленная в вашу матрицу, увеличивает объем хранения энергии на &e204.8 GFE&r."]
	quest.2E50F969D8AE49B2.title: "Элитная индукционная ячейка"
	quest.2E5D9CB5D821E96A.quest_desc: [
		"Самый &8прочный&r тип &bТрубы высокого давления&r. "
		""
		"Эти &bТрубы&r можно &2замаскировать&r, и они могут вмещать &bМодули для труб&r, что обеспечивает &eдополнительный функционал&r."
	]
	quest.2E73C8EDF463F426.title: "unlocks/gemstone_lights/any"
	quest.2E7A46639993CCDE.quest_desc: [
		"В любом мире есть секреты, &6скрытые&r за пределами видимого, будь то спрятанные &6под поверхностью&r или в совершенно другом &6измерении&r."
		""
		"Никогда не упускайте из виду то, что выглядит &6неуместно&r, возможно, вы откроете для себя что-то новое."
		""
		"Уверенность — это хорошо, но всегда оставайтесь &6во всеоружии&r и &6в безопасности&r; однажды это может спасти вам жизнь."
	]
	quest.2E7A46639993CCDE.quest_subtitle: "Из-за горы она выходит!"
	quest.2E7A46639993CCDE.title: "&bИсследования!"
	quest.2E81F371817EC492.title: "hidden/entity_interact/eraser"
	quest.2E883FCCA2FB281B.quest_desc: ["Установив два &bКвантовых кольца&f, вы сможете подключить свою &bМЭ Систему&f к любому месту в мире. Подключите первое кольцо к вашей &bМЭ Системе&f, а второе — туда, где вы хотите иметь доступ к вашей &bМЭ Системе&f. Вам понадобятся 2 &bСвязанные сингулярности&f: поместите по одной из них в каждое &bКвантовое кольцо&f, после чего они будут связаны друг с другом."]
	quest.2E883FCCA2FB281B.quest_subtitle: "Произведение искусства"
	quest.2E883FCCA2FB281B.title: "Квантовое кольцо"
	quest.2E97456B0ED0AB1A.quest_desc: [
		"&bЭлектрическая помпа&r — это &eосновной&r метод массового сбора &7жидкостей&r в мире."
		""
		"Поставьте её на один блок выше &7жидкости&r, которую вы хотите перекачивать, подайте &eэнергию&r, и подведите &9трубу&r или поставьте &9резервуар&r сверху, чтобы начать &6перекачку&r жидкости. "
		""
		"&bУлучшения&r могут значительно увеличить скорость её работы. "
		""
		"Совет для вас: она не потребляет &9блоки источника воды&r."
	]
	quest.2E97456B0ED0AB1A.title: "Электрическая помпа"
	quest.2EA3FE458DAB45EB.title: "unlocks/glowblocks/red_glowblock"
	quest.2EB0D8DB6C0D366F.title: "milestones/reveal_mermaids_brush"
	quest.2EE48762D9C66FDD.title: "hidden/discover_weeping_gala"
	quest.2F4B6DFC221E8B7C.title: "hidden/collect_vanilla/ender_eye"
	quest.2F4F94DCC3986B5B.title: "unlocks/potions/bad_omen"
	quest.2F53567C34E86536.quest_desc: ["Это самая базовая Книга заклинаний, она может вместить только пять Заклинаний"]
	quest.2F66F85A601AC908.quest_desc: [
		"{image:modern_industrialization:block/machines/macerator/overlay_top_active width:32 height:32 align:center}"
		"  Теперь вы можете &6полуучетверить ваши руды&r! Это означает, что у вас будет 50% шанс получить дополнительную пыль из вашей &bСырой руды&r. Вы также можете переработать &bЦельную руду&r и получить из неё много &bСырой руды&r, используя &bИзмельчитель (Macerator)&r."
		""
		"  Поскольку это &bИзмельчитель&r, вы можете забросить в него некоторые металлические предметы, чтобы &6переработать их обратно в пыль&r — хороший способ извлечь немного пользы из лута после приключений или из старого инструмента."
	]
	quest.2F66F85A601AC908.title: "Бронзовый измельчитель"
	quest.2F6C16939D136BF0.quest_desc: ["&bПлоскость истребления&f будет &6ломать блоки&f и &6подбирать&6&b предметы&f прямо перед собой."]
	quest.2F6C16939D136BF0.title: "МЭ Плоскости"
	quest.2F78D16A73C4598A.title: "unlocks/reagents/star_fragment"
	quest.2F7A213261682E1B.quest_desc: [
		"&bКотел для сжижения (Liquefaction Cauldron)&r &6замачивает&r ресурсы в &dрастворителе&r для получения из них &bСеры&r. Для протекания реакции требуется &6нагрев&r."
		""
		"Обратите внимание, что некоторые ресурсы, такие как руды, &aпроизводят более одной серы&r."
	]
	quest.2F8BDA9BE413F14A.title: "unlocks/glowblocks/green_glowblock"
	quest.2F9560A5281DCDFD.quest_desc: [
		"Нужно отвадить этих &cнадоедливых троллей&r от &bваших вещей&r? &6Приватьте их&r! "
		""
		"Вы можете создать &9Команду (Team)&r или &aприватить&r чанки в одиночку. "
		""
		"Чтобы &aзаприватить&r чанки соло, откройте свой &bинвентарь&r и посмотрите в &6верхний левый угол&r экрана. "
		""
		"Найдите &aкнопку с картой&r под названием \"&6Менеджер приватов (Claim Manager)&r\". С её помощью вы можете приватить разные &bучастки&r земли, называемые &aчанками&r. "
		""
		"Каждый &aчанк&r состоит из &b16x16 блоков&r, простирающихся от &5пустоты&r до &bнеба&r. "
		""
		"У вас есть &6ограниченное&r количество, так что не увлекайтесь. "
		""
		"Если вы хотите сначала создать &9Команду&r, найдите кнопку с надписью \"&6Ваша команда (Your Team)&r\", и она покажет вам список &aчленов команды&r и &3приватный чат&r. "
		""
		"Затем вы можете создать &eгруппу (party)&r, и изменить название и другие параметры вашей &eгруппы&r, &6нажав&r на значок &bшестеренки&r. "
		""
		"Вы можете &6приглашать&r других игроков, используя команду \"&a/ftbteams party invite&r\", после того как вы &6создали&r &eгруппу&r."
	]
	quest.2F9560A5281DCDFD.quest_subtitle: "&oМоя земля — это НЕ ваша земля."
	quest.2F9560A5281DCDFD.title: "&3Гильдии &7и &2Приваты"
	quest.2F993B0F106DB883.quest_desc: ["Используется для крафта предметов с помощью различных &bПрессовальных форм высекателя&f."]
	quest.2F993B0F106DB883.title: "Высекатель"
	quest.2FA7A5966FEF6701.quest_desc: ["&bСовершенная механическая труба&r имеет емкость &9128,000 мБ&r на каждую секцию трубы и скорость потока при \"&aвытягивании&r\" &932,000 мБ/т&r."]
	quest.2FA7A5966FEF6701.title: "Совершенная механическая труба"
	quest.2FAF4A09FDDD47AB.title: "hidden/collect_basal_marble"
	quest.2FB2FE782B1103D6.quest_desc: [
		"  Ваш второй многоблочный механизм: &bПаровая доменная печь&r! Она почти такая же, с той лишь разницей, что она на один блок выше и использует &bОгнеупорные кирпичи (Fire Clay Bricks)&r вместо обычных &bКирпичей&r."
		""
		"  Используйте тот же трюк с &bГаечным ключом&r, &6чтобы он показал вам расположение блоков&r, и не забудьте, что на этот раз вам понадобится всего &63 люка&r. Они такие же, как у &bКоксовой печи&r, только без люка вывода жидкости, по крайней мере, пока!"
		""
		"  Вы будете использовать эту &bПаровую доменную печь&r, чтобы получить свою первую &bСталь&r!"
	]
	quest.2FB2FE782B1103D6.title: "Паровая доменная печь"
	quest.2FC029A9E504ECE6.title: "unlocks/enchantments/serendipity_reel"
	quest.2FC0A2D07CC2DFC7.quest_desc: [
		"Примечание:"
		""
		"  В EMI — если посмотреть на Контроллер термоиспарения — будет представлен калькулятор постройки для Термоиспарительных установок."
		""
		"  Этот список задач является одним из рекомендуемых способов постройки установки минимальной высоты."
	]
	quest.2FC0A2D07CC2DFC7.title: "Термоиспарительная установка"
	quest.2FCE6346B5A5A85B.title: "unlocks/colored_lamps/magenta_lamp"
	quest.2FD9A01EF00E4D00.title: "milestones/unlock_spawner_manipulation"
	quest.2FF486B81AD3BF81.title: "unlocks/food/myceylon_pastries"
	quest.3009C3939976FBD2.quest_desc: ["&bТерминал крафта&f — это улучшенная версия &bТерминала&f. Он позволит вам крафтить, имея доступ ко всем вашим предметам."]
	quest.3009C3939976FBD2.title: "Терминал крафта"
	quest.300F6868FC217C55.quest_subtitle: "Пройди свой мир на 100%!"
	quest.300F6868FC217C55.title: "&6Перфекционист"
	quest.302BE63E3488B94D.quest_desc: [
		"Просто ещё один предмет для крафта. "
		"Посмотрите рецепт в &bEMI/JEI&r."
	]
	quest.30396F5AD792EABD.title: "unlocks/colored_lamps/brown_lamp"
	quest.3047758B41C1DCD4.title: "unlocks/enchantments/vanilla_treasure"
	quest.305C258D68DA8E96.quest_desc: ["В &bИндукционном корпусе&r будут размещаться ячейки и провайдеры, которые позволят вам &6хранить&r невероятные объемы &eчистой энергии&r."]
	quest.305C258D68DA8E96.title: "Индукционный корпус"
	quest.305EDA1DA23E9BDF.quest_desc: ["Стражи порядка в непредсказуемом мире &bЦепей,&r &bКонвейеров,&r и &bКоробок&r."]
	quest.305EDA1DA23E9BDF.quest_subtitle: "Упакуй их снова, Сэм."
	quest.3065BBCE6E4844FD.title: "unlocks/memory_to_head"
	quest.3068A4024A893DF9.quest_desc: ["Если вы сможете найти путь к биому Бледной рощи, вы можете обнаружить эти жуткие тыквы..."]
	quest.3068A4024A893DF9.title: "Бледная тыква"
	quest.306D260B0FF93881.title: "unlocks/trinkets/lesser_potion_pendant"
	quest.306E118494E0FA08.title: "Синий светящийся тростник"
	quest.308640ACCC096431.quest_desc: [
		"&bМЭ Контроллер&f — это первый большой шаг к созданию вашей &bМЭ Системы&f. К &bМЭ Контроллеру&f нужно &6подвести энергию&f, но её не потребуется много."
		""
		"Обеспечивает до 32 каналов на каждую сторону. Чтобы использовать все эти каналы, вам необходимо передавать их с помощью &bПлотных кабелей&r, так как обычные кабели передают только до 8 каналов."
		""
		"ПРИМЕЧАНИЕ: &lТОЛЬКО&r &bПлотные кабели&r передают более 8 каналов; &bИнтерфейсы&r, &bПоставщики шаблонов&r и т.д. могут пропускать через себя только 8 каналов, даже если они подключены к &bПлотному кабелю&r."
	]
	quest.308640ACCC096431.title: "Центр хранилища"
	quest.30A0D33361D77D7E.quest_subtitle: "Поймайте &a25&r рыб в общей сложности."
	quest.30A6129113D095B8.title: "unlocks/trinkets/totem_pendant"
	quest.30BD7370506EBC6C.title: "Кислород"
	quest.30D584EAD9243548.quest_desc: [
		"&bЖидкостный наполнитель (Fluidic Plenisher)&r позволяет вам &6снабжать&r его &7жидкостью&r, и он будет заполнять ею пустые пространства под собой. "
		""
		"Это позволит вам создавать целые озера из любой &7жидкости&r, какой пожелаете."
	]
	quest.30D584EAD9243548.title: "Жидкостный наполнитель"
	quest.30D8364FACD3277C.title: "unlocks/reagents/lapis_lazuli"
	quest.30ED8D5374012D92.quest_desc: ["Бутылочка с молнией (Bottle o' Lightning) получается путем нажатия ПКМ пузырьком по заряженному криперу."]
	quest.30EFAD6A12703DE6.title: "unlocks/equipment/omni_accelerator"
	quest.30FB66E92909D4B9.quest_subtitle: "Все Селитры"
	quest.30FB66E92909D4B9.title: "&bАлхимическая селитра"
	quest.30FC83AF65C13591.quest_desc: ["Как и &bАндезитовый туннель&r, но с режимами &6фильтрации&r и &6распределения&r."]
	quest.310A2BED5A70A2BB.title: "unlocks/items/natures_staff"
	quest.31203D3E004E1DAB.title: "Хлор"
	quest.3143EA7DF096CE61.quest_desc: [
		"  Новый механизм! Этот может быть сделан только из стали; ему действительно нужна эта дополнительная прочность."
		""
		"  &bУпаковщик (Packer)&r может выполнять для вас простые рецепты крафта. Вы можете &6автоматизировать создание двойных слитков, труб, многих видов кирпичей и многого другого&r! Проверьте EMI для получения дополнительных рецептов."
	]
	quest.3143EA7DF096CE61.title: "Стальной упаковщик"
	quest.314C3572AA2F2E83.title: "unlocks/redstone/redstone_timer"
	quest.314F299A677D92A6.quest_desc: [
		"Главное назначение: хранение зелий (до &9100 зелий&r одного вида). "
		"&8(также выступает в качестве хранилища, необходимого для работы &bРаспылителя зелий (Potion Diffuser)&r \\& &bСмесителя зелий (Potion Melder)&r)"
		""
		"- Используйте его вместе с &5Викси&r: автоматическое создание зелий."
		""
		""
		"&4ПРИМЕЧАНИЕ&r: нажмите &6Shift + ПКМ&r &bЖезлом Доминиона&r, чтобы заблокировать банку."
	]
	quest.3161170FE857BAF3.title: "milestones/unlock_hostile_memorizing"
	quest.3174BA813A3B15DF.title: "unlocks/colored_lamps/orange_lamp"
	quest.3189264EB89A2A5A.quest_desc: [
		"Я знаю, что во время вашего путешествия вы столкнетесь с некоторыми &6неудобствами&r; поэтому я окажу вам некоторую помощь с ними. "
		""
		"Есть &6три основные вещи&r, скажете спасибо позже."
	]
	quest.3189264EB89A2A5A.quest_subtitle: "&oСекреты мастерства"
	quest.3189264EB89A2A5A.title: "&aПолезные советы и хитрости"
	quest.31BF4B67627E635C.title: "unlocks/equipment/soothing_bouquet"
	quest.31D5374CE1F8E674.title: "unlocks/enchantments/vanilla_protection"
	quest.31D8FD32507C53C1.title: "unlocks/food/karak_chai"
	quest.31E97F2E362F0308.title: "unlocks/equipment/dreamflayer"
	quest.320C2F44DD138054.quest_desc: [
		"В отличие от других боссов, это животное не предназначено для убийства. "
		""
		"Вместо этого игрок должен выполнить его &6Квест&r, дав ему &bШерсть&r всех возможных цветов."
		""
		"Шерсть можно передать ему, бросив &bШерсть&r под ноги &cБарану&r, или использовав &bШерсть&r прямо на него. "
		""
		"Каждый раз, когда ему дают блок &bШерсти&r, его тело будет удлиняться, и на нем будет появляться полоса шерсти этого цвета. "
		""
		"Когда его квест будет выполнен, он выбросит &6Трофей&r, что завершит этот квест."
	]
	quest.320C2F44DD138054.quest_subtitle: "Дружелюбный босс-животное, обитающее в &6Квестовой Роще (Quest Grove)&r, которую можно найти только в биоме &dЗачарованного леса&r."
	quest.320C2F44DD138054.title: "&3Квестовый Баран"
	quest.320F924B4D0D5EE6.quest_desc: [
		"Бобр увеличивает &6скорость&r, с которой вы добываете &bдревесину.&r"
		""
		"Он также будет пытаться &6рубить&r &bдеревья.&r"
	]
	quest.320F924B4D0D5EE6.quest_subtitle: "Сколько дров мог бы нарубить лесоруб, если бы лесоруб мог рубить дрова?"
	quest.3223A4C341AE8F89.title: "triggers/hints/midnight_chip_page1"
	quest.32241ABD0AB30090.title: "hidden/collect_blackslag"
	quest.322A0B6AC3347EB4.quest_desc: [
		"• &cРентген (X-Ray)&r"
		"• &cМгновенное разрушение&r"
		""
		"{image:justdirethings:item/eclipsealloy_paxel_active width:100 height:100 align:center fit:true}"
	]
	quest.324CD5C25A88141F.title: "unlocks/trinkets/gloves_of_dawns_grasp"
	quest.324EB8165298F503.quest_desc: ["&bЭлитная логистическая транспортная труба&r может втягивать в транспортную сеть по &a64 предмета в секунду&r и передавать их со скоростью &a4.0 метра в секунду&r."]
	quest.324EB8165298F503.title: "Элитная логистическая транспортная труба"
	quest.3254374A45D0D708.quest_desc: [
		"Используйте &bСхему и Перо (Schematic and Quill)&r, чтобы &6сохранить&r постройку или кусок вашего мира."
		""
		"Используйте &bПустую схему&r в &bСтоле для схем&r, чтобы &6привести ваши схемы&r в действие."
	]
	quest.3254374A45D0D708.quest_subtitle: "Чистый лист... что вы напишете на своем?"
	quest.32546FB541B4AD64.title: "hidden/collect_cookbooks/poisoners_handbook"
	quest.325A0651CB2D1279.quest_desc: [
		"Этот механизм подвергает &cПустые печатные платы&r воздействию &eУФ-света&r, подготавливая их к &6обработке&r в &bТравильном баке&r."
		""
		"Более длительное &eвремя воздействия&r повышает вероятность &aуспешного травления&r, хотя со временем процесс &7замедляется&r. "
		""
		"Вы можете установить &3порог&r, чтобы определить, когда &bПечатная плата (PCB)&r считается &aготовой&r; &eболее низкий порог&r ускоряет &6обработку&r, но увеличивает риск &cнеудачного травления&r. "
		""
		"&cБракованные печатные платы&r можно &2переработать&r в &8Доменной печи (Blast Furnace)&r для повторной попытки."
	]
	quest.325D7C592E2FB05A.quest_desc: [
		"  &bКонечное&r состояние твёрдой материи, сжатой настолько сильно, что она превращается в точку бесконечной плотности и гравитации."
		""
		"  Тем не менее, вы можете сдерживать её, чтобы использовать для различных задач. В ваших руках... &bБесконечность&r."
	]
	quest.325D7C592E2FB05A.title: "Сингулярность"
	quest.32677D1F144A1184.quest_desc: ["Демонические Партнеры обязаны служить вам и составлять компанию. Они бывают в двух формах — почему бы не призвать обеих?"]
	quest.32677D1F144A1184.quest_subtitle: "..."
	quest.32677D1F144A1184.title: "Призыв Демонических Партнеров"
	quest.327EDC1D4C50D185.quest_desc: ["&dQIO Экспортер&r специально создан для &aизвлечения&r предметов из вашей системы в блок, на который установлен узел экспортера."]
	quest.327EDC1D4C50D185.title: "QIO Экспортер"
	quest.3288EB24E412AF9A.quest_subtitle: "Завершите главу квестов."
	quest.3288EB24E412AF9A.title: "&dModern &bIndustrialization"
	quest.328E672F6B43D93A.quest_desc: ["И для &6сборки&r ваших поездов, и, собственно, для того, чтобы &6быть&r железнодорожными станциями."]
	quest.3295D859B01FA315.quest_desc: ["Эта &bкнига&r — ваш &3журнал коллекции&r всего, что связано с рыбалкой: от &5редкой рыбы&r до &6блестящих трофеев&r."]
	quest.3295D859B01FA315.quest_subtitle: "Сказка рыбака"
	quest.3295D859B01FA315.title: "&bРуководство Звездолова"
	quest.32A5829D5382E432.title: "unlocks/equipment/nightfalls_blade"
	quest.32B4C48622EEE090.title: "unlocks/trinkets/radiance_pin"
	quest.32DC17E21BF26228.quest_desc: ["Используйте это, чтобы &6загрузить&r сохранённые &bСхемы&r в новую &bСхему&r, готовую к использованию в &bСхемопушке (Schematicannon).&r"]
	quest.32EA5C9F5065B409.title: "unlocks/food/sawblade_holly_titration"
	quest.33163F99B5693C3D.title: "hidden/status_effects/another_roll"
	quest.332ECB6DA4C2BF96.title: "unlocks/reagents/nightdew_sprout"
	quest.3336B50DED50F792.title: "milestones/unlock_complex_reagents"
	quest.33380F675DAF36F4.title: "triggers/hints/quitoxic_reeds_page1"
	quest.333A9CB8307CB431.title: "triggers/hints/downstone_fragments_page1"
	quest.33413A32ECEEC7D2.title: "unlocks/food/demon_trifle"
	quest.3357A8B614D477B6.quest_desc: [
		"  Новый механизм, младший брат &bУпаковщика&r! Он может быть сделан только из стали; ему действительно нужна эта дополнительная прочность."
		""
		"  &6Распаковщик (Unpacker) может выполнять для вас простые рецепты крафта, например, превращать пыль в крошечную пыль&r. Проверьте EMI для получения дополнительных рецептов."
	]
	quest.3357A8B614D477B6.title: "Стальной распаковщик"
	quest.335BFE2345DAFE03.quest_desc: [
		"Для &bЭлектрической бензопилы&r:"
		"- Нажмите &6Левый Shift&r и &6ПКМ&r, чтобы переключаться между &bУдачей/Добычей&r и &bШёлковым касанием&r."
		""
		"Для &bЭлектрического шахтёрского бура&r:"
		"- Нажмите &6Левый Shift&r и &6ПКМ&r, чтобы переключаться между &bУдачей&r и &bШёлковым касанием&r."
		""
		"Для &bобоих&r:"
		"- Используйте &6Alt&r и &6Колёсико мыши&r, чтобы изменить скорость добычи."
	]
	quest.335BFE2345DAFE03.title: "Электрические аксессуары"
	quest.336842A5AE730DF1.title: "unlocks/trinkets/radiance_pin"
	quest.337C66CF05695CB8.title: "triggers/hints/malachite_page1"
	quest.3392424E7E1B68C4.quest_desc: [
		"Нужна &bцентрифуга&r? "
		"Нужна та, что &aпобыстрее&r? "
		""
		"Как насчёт такой, которая &6вращается как ракета&r, привязанная к &9детской карусели&r? "
		""
		"Тогда &bИзотопная центрифуга&r — это то, что вам нужно! "
		""
		"Используйте её для переработки &2ядерных отходов&r, а также для создания вашего &dрасщепляемого топлива&r."
	]
	quest.3392424E7E1B68C4.title: "Изотопная центрифуга"
	quest.33AC5F9CFB679483.quest_desc: [
		"Нам нужны глаза, чтобы видеть, и было бы хорошей идеей держать их в безопасности; &bШлем MekaSuit&r сделает именно это. "
		""
		"Вы даже можете получить &5Ночное зрение&r!"
	]
	quest.33AC5F9CFB679483.title: "Шлем MekaSuit"
	quest.33C2042F320B2D34.quest_desc: [
		"Желоба (Chutes) гораздо более гибкие, чем может показаться на первый взгляд."
		""
		"Они могут соединяться не только по вертикали, но и по диагонали."
		""
		"Гаечный ключ позволяет вставлять или убирать окошки в Желобах."
		""
		"Перемещает предметы вверх, используя Вентиляторы в корпусе на любом из концов, чтобы нагнетать воздух наверх."
		""
		"Перемещает предметы вниз с помощью... ничего другого. (спасибо гравитации!)"
	]
	quest.33C2042F320B2D34.quest_subtitle: "Ну, Желоб (Chute)."
	quest.33CD5343AFBF853C.quest_desc: [
		"Перемещение &5истока&r из точки А в точку Б."
		""
		"- Используйте &bЖезл Доминиона&r для привязки."
		"&8чтобы очистить настройки, нажмите &6Shift + ПКМ&r &8Жезлом Доминиона."
		""
		"- Расстояние: &930 блоков&r."
	]
	quest.33CD5343AFBF853C.quest_subtitle: "Передача Истока"
	quest.33CDCAD12E8F6828.quest_desc: ["Максимальное количество тиков между спавном."]
	quest.33CDCAD12E8F6828.quest_subtitle: "-10 Максимальная задержка спавна"
	quest.33CEED6232901CE5.quest_desc: ["При &6совместном использовании&r с &bВакуумной ловушкой&r, этот механизм будет &6засасывать&r любых &7мобов&r рядом с ним и помещать их в &bЯдро спавнера&r. Чтобы это сработало, вы должны сначала &6скрафтить&r &bЯдро спавнера&r и &6вставить&r его в &bВакуумную ловушку&r."]
	quest.33D0760B5FEF7C46.quest_desc: [
		"  &oЭто&r — совершенный генератор."
		""
		"  &bПлазменная турбина&r использует &bГелиевую плазму&r для производства энергии, &6до 1,048,576 EU/t&r. Это около 100,000 EU на миллибакет &bГелиевой плазмы&r при &6скорости потребления около 11 мБ/т&r."
		""
		"  Если вы знаете, как заботиться о своей фабрике, вам &oникогда&r больше не придется беспокоиться о нехватке энергии."
	]
	quest.33D0760B5FEF7C46.title: "Плазменная турбина"
	quest.33D408D68729A378.title: "unlocks/items/bottle_of_decay_away"
	quest.33D4B0B289A55EC9.title: "unlocks/items/experience_bottle"
	quest.33EEBDD0730C020E.quest_desc: ["Используйте Кузню свитков и Пузырёк крови для создания Свитков крови."]
	quest.33F07E292A9B14B1.quest_desc: ["&bЯдро телепортации&r — это сердце &6телепортации&r не только ресурсов, но и людей."]
	quest.33F07E292A9B14B1.title: "Ядро телепортации"
	quest.33F695229D12C6FB.quest_subtitle: "Высуши эту смолу"
	quest.3423502520249615.title: "unlocks/equipment/dreamflayer"
	quest.3438F71F3FE2FD49.title: "unlocks/potions/strong_sleep_effects"
	quest.3442EB0EFAD95794.title: "unlocks/equipment/gemstone_armor_category"
	quest.3447A04FA017C790.quest_desc: [
		"!!! ПРЕДМЕТЫ НА &bПЬЕДЕСТАЛАХ&r НЕ БУДУТ ИЗРАСХОДОВАНЫ !!!"
		""
		"&8Главный предмет (по центру в рецепте EMI)"
		"&8Дополнительные предметы (вокруг главного предмета)"
		"&l1. Как использовать?&r "
		"Положите &bдополнительные предметы&r на &bПьедесталы&r &8(если это требуется по рецепту)&r -> поместите &bглавный предмет&r в &bКамеру наполнения (Imbuement Chamber)&r"
		"-> подождите завершения процесса -> заберите результат из &bКамеры наполнения&r."
		""
		"&l2. Размещение&r"
		"&8P = Пьедестал  |  I = Камера наполнения "
		"P P P"
		"P I P"
		"P P P"
		"&8(совет: Пьедесталы могут находиться на 1 блок выше/ниже)&r"
		""
		""
		"&4ПРИМЕЧАНИЕ 1&r: для работы не требуется &5исток&r. (но процесс можно ускорить с помощью &5истока&r)."
		"&4ПРИМЕЧАНИЕ 2&r: ПОДАЧА \\& ИЗВЛЕЧЕНИЕ предметов могут быть автоматизированы с помощью &bтруб&r."
		""
		"!!! ПРЕДМЕТЫ НА &bПЬЕДЕСТАЛАХ&r НЕ БУДУТ ИЗРАСХОДОВАНЫ !!!"
	]
