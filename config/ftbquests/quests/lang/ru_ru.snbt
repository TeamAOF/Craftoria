	quest.28D8463C6036B3BF.title: "Дыня Хами"
	quest.28EB489B44A05070.quest_desc: ["&aРепликаторы&r будут использовать &dМатерию&r, хранящуюся в резервуарах, чтобы создать предмет с нуля и отправить его обратно в &bтерминал&r."]
