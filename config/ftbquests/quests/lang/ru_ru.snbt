	]
	quest.03271CEB2EBD0979.quest_subtitle: "Массовое зарядное устройство (AOE)"
	quest.03289E3820CA7185.title: "triggers/hints/storm_stones_page0"
	quest.033CE547B7A088D4.title: "hidden/status_effects/deadly_poison"
	quest.038773FFAF3C8817.quest_desc: [
		"  Воспринимайте эту главу как блок-схему."
		""
		"  Каждый тир начинается с задания по рудному блоку."
		""
		"  &6Вход&r &bРудные блоки&r : &6Выход&r &bСлитки&r, для каждого тира:"
