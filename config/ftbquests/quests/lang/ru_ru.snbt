	quest.4E808F3774D5350E.title: "triggers/hints/topaz_page0"
	quest.4E8963E1C18ADBAB.quest_desc: [
		"&bИнкубатор&r — это небольшая многоблочная структура, используемая для рекомбинации Принципов материи в объекты."
		""
		"Она состоит из &bсосудов&r всех трех типов, размещенных по бокам — &bСоли (Salt)&r, &bСеры (Sulfur)&r и &bРтути (Mercury)&r — самого &bИнкубатора&r и источника &6тепла&r внизу, в данном случае &bПиромантической жаровни (Pyromantic Brazier)&r."
	]
	quest.4E8963E1C18ADBAB.quest_subtitle: "Внимание: Это не для яиц"
	quest.4E91750FEC86B624.title: "unlocks/items/celestial_pocketwatch"
	quest.4E97BABA7D6B07FE.quest_desc: [
		"Пассивная ферма культур \\& деревьев."
		""
		"- Радиус: &910 блоков&r от &bЦветка Вирлисприга (Whirliprig Blossom)&r."
		""
		"- Прогресс: 250. (по умолчанию)"
		""
		"- Как получить больше лута*: главное — разнообразие."
		"- Как быстрее заполнить шкалу прогресса*: главное — количество."
		""
		"- Призыв: нажмите &6ПКМ&r по &bцветку&r "
		"&8(превратит цветок в Цветок Вирлисприга)&r"
		""
		"- Использование Вирлисприга: разместите &bхранилище&r &6вплотную&r к &bЦветку Вирлисприга&r."
		"W: Цветок Вирлисприга | "
		"C: сундук (или другие хранилища)"
		" C "
		"CWC"
		" C"
		""
		"- Требуется ли исток: ДА."
		""
		""
		"&8*Глубокий разбор Вирлисприга на &bследующей странице &8(в разработке)"
		""
		"{@pagebreak}"
		"&2Вирлисприг&r рассматривает блоки в &93 состояниях&r (когда вы нажимаете на него &6ПКМ&r с блоком в руке):"
		"&8- НЕМНОГО_НРАВИТСЯ (KINDA_LIKES) (обычное повышение настроения), +1 "
		"&8- ОЧЕНЬ_НРАВИТСЯ (GREATLY_LIKES) (наибольшее повышение настроения), +2"
		"&8- ОТКАЗАНО_В_ДРОПЕ (DENIED_DROP)"
		""
		"Затем у него есть еще 3 числа для отслеживания:"
		"&8- Оценка настроения (moodScore) (влияет на &6прогресс&r&8; выражается тем, насколько он &2\"счастлив\"&r&8)"
		""
		"&8- Оценка разнообразия (diversityScore) (сколько &9раз&r &8он берет предметы из сгенерированной таблицы лута)"
		"&8сколько уникальных &6ПРИНЯТЫХ&r &8блоков/культур вокруг него"
		""
		"&8- Прогресс (когда он заполнен, он генерирует &6лут&8)"
		"&8прогресс += &6Оценка настроения (moodScore)&r &8/ 30;"
		"&8сбрасывается на 0 после помещения лута в хранилище;"
		""
		"&8Для нормальных людей: новый_прогресс = старый_прогресс + &6Оценка настроения&r &8/ 30;"
		""
		"&8Не могу поверить, что здесь есть 3 страница ..."
		"{@pagebreak}"
		"&lКак это работает в коде:&r"
		"1. Вычисляет &bmoodScore (Оценку настроения)&r из &9ВСЕХ&r блоков в радиусе действия. (он проверяет каждый блок)"
		"&8(после &950-го&r &8блока/растения одного типа, он БОЛЬШЕ &6НЕ&r &8будет засчитывать этот блок/растение)"
		""
		"2. Увеличивает прогресс до заполнения."
		""
		"3. Генерирует таблицу лута."
		""
		"4. Выполняет getDrops() &8((diversityScore / 2) + 3)&r раз"
		"&8Вам придется разобраться с этим самостоятельно (для меня это слишком)"
		"&8Файл: WhirlisprigTile.java"
		""
		"5 Помещает результат в &bблок хранилища&r рядом с цветком."
	]
	quest.4E97BABA7D6B07FE.quest_subtitle: "Ферма Культур \\& Деревьев"
	quest.4EA0C90A02A43131.quest_desc: [
		"&bКамера реакций под давлением (Pressurized Reaction Chamber)&r принимает &3твердые вещества&r, &7жидкости&r и &eгазы&r для производства других &3твердых веществ&r и &eгазов&r в среде под давлением."
		""
		"&6Проверьте&r EMI, чтобы узнать, для чего конкретно вы можете ее использовать."
	]
	quest.4EA0C90A02A43131.title: "Камера реакций под давлением"
