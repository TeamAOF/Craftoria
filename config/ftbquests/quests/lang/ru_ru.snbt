	quest.03030E8B6522BA85.title: "hidden/collect_sawblade_holly_berry"
	quest.030E566682A89105.quest_desc: [
		"   В &bканистре с топливом&r помещается большой объем топлива."
		""
		"   Её можно поместить в любой слот, который обычно принимает топливо."
		""
		"   Но самое лучшее... &oона перестаёт расходовать свой внутренний запас&r, когда больше нечего &6переплавлять&r, &6коптить&r, &6сжигать&r или &6генерировать энергию&r."
		""
		"  Это поможет вашим запасам топлива прослужить дольше."
		""
		"{image:justdirethings:item/fuel_canister_full width:100 height:100 align:center fit:true}"
	]
