	quest.117C9FABE86447D1.quest_desc: ["&bКвантовый энтангопортировщик&r позволяет мгновенно &6транспортировать&r &bпредметы&r, &7жидкости&r, &eгазы&r, &4тепло&r, &dпигменты&r, &9суспензии&r, &aнаполняющие материалы&r и &6энергию&r куда угодно, как и &bТелепорт&r."]
