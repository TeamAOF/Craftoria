	quest.4CF10B1859DB33AF.title: "unlocks/blocks/crystal_apothecary"
	quest.4D02897DB2CE4C25.title: "Васаби"
	quest.4D05AA18CF654D70.quest_desc: [
		"  &bИнструменты и Оружие из Феррикора (Ferricore)&r такие же прочные и долговечные, как их &bжелезные аналоги&r."
		""
		"  Они также могут быть &6улучшены&r до более высоких тиров с помощью соответствующего &bшаблона кузнеца (template)&r."
		""
		"  Они могут принимать &bулучшения&r для получения разнообразных &6особых способностей&r."
		""
		"• &bКирка&r: &cШахтёр руд (Ore Miner)&r, &cСканер руд (Ore Scanner)&r"
		"• &bТопор&r: &cЛесоруб (Tree Feller)&r, &cРазрушитель листвы (Leaf Breaker)&c"
		"• &bЛопата&r: &cГазонокосилка (Lawn Mower)&r, &cОчиститель неба (Sky Sweeper)&r"
		"• &bМеч&r: &cСканер мобов (Mob Scanner)&r"
		"• &bЛук&r: &cСтрела с зельем (Potion Arrow)&r"
		"• &bМотыга&r: на этом тире улучшений нет"
		""
		"{image:justdirethings:item/ferricore_axe_active width:100 height:100 align:center fit:true}"
	]
