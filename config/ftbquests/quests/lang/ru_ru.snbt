	quest.0EA9EF2362AE52A2.title: "Базовая фабрика очистителей"
	quest.0EB458202391B405.title: "unlocks/enchantments/vanilla_quitoxic"
	quest.0EB8636489EB02DE.quest_desc: [
		"Аддон Ars Nouveau + Occultism."
		""
		"&8Для получения дополнительной информации, пожалуйста, загляните в книгу &5Ars Nouveau&8."
		"&8- Духов теперь можно использовать из Банок удержания!"
		"&8- Духи автоматически собирают предметы вокруг себя в области 7x7 и перерабатывают их."
		"&8- Духи-уборщики будут пытаться протолкнуть свое содержимое в хранилище поверх банки."
		"&8- Игрок также может нажать ПКМ предметом по банке, чтобы переработать его."
		"&8- И многое другое..."
	]
	quest.0EB8636489EB02DE.quest_subtitle: "Occultism"
	quest.0EB8636489EB02DE.title: "Аддон Ars Ocultas"
	quest.0EBF393C150ABFA9.title: "unlocks/items/incandescent_amalgam"
	quest.0ECDE9598DABBD3A.quest_desc: [
		"• &cШахтёр руд&r, &cСканер руд&r"
		"• &cГазонокосилка&r, &cОчиститель неба&c"
		"• &cЛесоруб&r, &cРазрушитель листвы&c"
		"• &cАвтоплавильня&r"
		"• &cМолот&r"
		"• &cТелепорт дропа&r"
		""
		"{image:justdirethings:item/celestigem_paxel_active width:100 height:100 align:center fit:true}"
	]
	quest.0ED4263270D37EF6.quest_desc: [
		"&eДизельные аксессуары&r"
		""
		"  Есть несколько мощных инструментов и аксессуаров, работающих на &6дизельном топливе&r, которые вы можете использовать для дальнейшего расширения вашей фабрики. Вот они:"
		""
		" &#8226; Первый — это &bДизельный бур&r, огромное улучшение по сравнению с вашим старым паровым буром. Разница в том, что здесь вы больше не можете использовать функцию копки 3x3, но можете &6переключаться между «Шёлковым касанием» и «Удачей III»&r с помощью простого нажатия Shift+ПКМ. Чем мощнее топливо в нём, тем быстрее он копает."
		""
		" &#8226; Вторая — &bДизельная бензопила&r. Бензопила имеет точно такой же функционал, как и бур, но предназначена для вырубки деревьев и тому подобного, чтобы заменить ваш топор."
		""
		" &#8226; Третье — &bДизельный джетпак&r. Да, вы не ослышались. Джетпак. Чем &6мощнее топливо&r в нём, тем &6быстрее вы будете летать&r. Используйте клавишу \"V\", чтобы включать и выключать джетпак. Дайте волю своим крыльям и летайте с помощью силы технологий! &oИ капельки топлива...&r"
	]
	quest.0ED4263270D37EF6.title: "Дизельные аксессуары"
	quest.0ED5CB1120D1BD6E.quest_desc: ["Свитки можно найти по всему миру во время исследований, но если вы не будете осторожны и решите использовать Свиток, он будет иметь только одно использование."]
	quest.0ED5CB1120D1BD6E.title: "Свиток"
