	quest.4DB10666349CCDBD.title: "hidden/unlock_explard_hint"
	quest.4DBDCEA0761F1D3B.quest_desc: [
		"&bВарп-свитки (Warp Scrolls)&r используются для телепортации или для создания &5постоянного портала&r. "
		"&8+ Телепортироваться самому: используйте свиток в &6основной руке"
		"&8+ Телепортировать моба: сотворите заклинание с &5глифом Скачка (Blink)&8, когда свиток находится в &6левой руке (offhand)"
		""
		"- &bВарп-свиток&r: телепортирует вас в заданную точку."
		"&8Количество использований: 1 раз"
		"&8Межпространственный: НЕТ"
		""
		"- &bСтабилизированный Варп-свиток&r: создает &5временный портал&r, который вскоре исчезнет."
		"&8Количество использований: неограниченно"
		"&8Межпространственный: ДА"
		""
		""
		"&8Совет 1: чтобы &6задать&8 точку, нажмите ПКМ (работает только для &bпустого Варп-свитка&8)."
		"&8Совет 2: чтобы &6сбросить&8 точку, сделайте бесформенный крафт свитка (вы можете использовать сетку 2x2 в вашем инвентаре :P )."
		""
		""
		"&4ПРИМЕЧАНИЕ&r: для создания &5постоянного&r портала, загляните в &bследующий квест&r."
	]
