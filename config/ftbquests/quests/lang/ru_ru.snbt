	quest.5B34A2176998C9A4.title: "Инжир"
	quest.5B3657CFD8B4CA57.title: "unlocks/blocks/memories"
	quest.5B3CF4D37F86A481.title: "unlocks/food/gatorwine"
	quest.5B47799A9001A3A0.title: "hidden/collect_pigment/blue"
	quest.5B53082C03CD729F.title: "unlocks/trinkets/any_azure_dike_equipment"
	quest.5B56FF9AC9CF977E.title: "unlocks/trinkets/fanciful_pendant"
	quest.5B578B176E3E3280.quest_desc: [
		"🎉🎉🎉🎉🎉🎉"
		""
		"Вот, возьмите немного &bМяса Вардена (Warden's Meat)&r. "
		"&8Что с ним делать? Решать вам 😈"
		""
		"Что дальше?"
		"&8Вы можете изучить аддоны (например, Ars Elemental)"
		"&8Или, возможно, попробовать сделать всё, что может предложить мод (если вы еще не занимались зельеварением, фермами с помощью фамильяров и турелями)"
		""
		"🎉🎉🎉🎉🎉🎉"
	]
	quest.5B578B176E3E3280.title: "🎉🎉🎉"
	quest.5B7B6800B58111CC.title: "unlocks/items/bottle_of_fading"
