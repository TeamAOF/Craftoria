	quest.34EB0A047332C35A.title: "milestones/reveal_quitoxic_reeds"
	quest.3500610FAB47D261.title: "unlocks/trinkets/artists_palette"
	quest.3504BCE26041D225.quest_desc: [
		"&bКамера реакций (Reaction Chamber)&f позволит вам &6создавать&b Кристаллы&r и &bОсобые слитки&f из &bAE2&f с затратами &4ЭНЕРГИИ POWAH&f."
		""
