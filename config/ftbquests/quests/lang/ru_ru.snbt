	quest.135F82F19257242A.title: "unlocks/pylons/onyx_pylon"
	quest.135FBE79D4415F15.quest_desc: [
		"  Прежде чем вы спросите: ответ — нет. Эти &bядерные бомбы&r &oне&r взрываются. Это ядерные заряды без детонатора. "
