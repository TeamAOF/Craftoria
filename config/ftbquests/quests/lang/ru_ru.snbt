	quest.152711890E79B5F7.title: "unlocks/glowblocks/blue_glowblock"
	quest.15286C95948B38E8.title: "unlocks/enchantments/vanilla_protection"
	quest.15325B16AFE33D5C.quest_desc: ["Вам понадобится &bЖир&r, чтобы сделать правильные оккультные свечи. Убийство &6крупных животных&r любым &bножом&r позволит вам добыть немного жира."]
	quest.15325B16AFE33D5C.quest_subtitle: "Инструменты ремесла"
	quest.15325B16AFE33D5C.title: "Ножи"
	quest.1560BC273E27875B.title: "unlocks/blocks/shimmerstone_lights"
	quest.1561B898CA3CA422.title: "unlocks/enchantments/vanilla_trial_breaching"
	quest.156575F76CAB51A0.quest_desc: [
		" Вы достигли &dБЕСКОНЕЧНОСТИ&r. "
		""
		"Вы больше не ограничены тем, что можете или не можете создать. "
		""
		"Ваши &6возможности&r теперь почти &bбезграничны&r. "
		""
		"Используйте &dУниверсально применимую материю&r, чтобы &6дублировать&r всё, что пожелаете, но с одним &dограничением&r. "
		""
		"Помните, &dматерия&r не может быть создана из &bничего&r, поэтому попытки &6продублировать&r сильно &bсжатые&r блоки или &bрюкзак&r, полный &bпредметов&r, будут тщетны. "
		""
		"В остальном вы вольны делать то, что вам угодно. Используйте эту новообретённую &6силу&r с умом!"
	]
