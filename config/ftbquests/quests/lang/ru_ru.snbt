	quest.05204F6C709B47BE.title: "unlocks/blocks/ender_blocks"
	quest.053F19ACEEAC0233.title: "unlocks/trinkets/fanciful_gloves"
	quest.0541F90AD95B4B5E.quest_desc: ["Обратите внимание: на &bДепо&r может &6создаваться&r одно, а в &bЧаше&r — совсем другое."]
	quest.0541F90AD95B4B5E.quest_subtitle: "Могу ли я предложить вам сэндвич с огурцом?"
	quest.054643E17B416240.title: "unlocks/ampoules/raw_malachite_ampoule"
	quest.0547229FF5334CF5.quest_desc: ["&bИнтерфейс&f работает как сундук. Вы можете &aнастроить предмет или жидкость&f внутри &bИнтерфейса&f, и он будет забирать этот предмет из &5сети&f, чтобы поддерживать его запас."]
	quest.05658FB0767F9CC0.title: "unlocks/items/staff_of_remembrance"
	quest.056A61638566C7DC.title: "unlocks/colored_saplings/black_sapling"
	quest.056ED1EBDE1F5940.title: "triggers/hints/mermaids_gems_page1"
	quest.0578945AE9664476.quest_subtitle: "Dropped within the Trials of Awaken gateway. "
	quest.057EBA4A86962504.title: "unlocks/equipment/resonant_pickaxe"
	quest.059210104BE29DB3.title: "unlocks/gemstone_chimes/topaz_chime"
	quest.059D14148B6D2071.title: "hidden/collect_every_pure_cmy_resource"
	quest.059D284AFBC6B0CD.title: "hidden/status_effects/somnolence"
	quest.05A0AC380BB141A0.quest_desc: ["&bОграничивающая транспортная труба&r — это тип &bЛогистической транспортной трубы&r, которая фактически работает как труба для \"&6излишков&r\". Как только &3предметам&r станет некуда деваться, они &6направятся&r через &bОграничивающую транспортную трубу&r."]
	quest.05A0AC380BB141A0.title: "Ограничивающая транспортная труба"
	quest.05B2AA73EAEDCCF4.quest_desc: [
		"Эти &bШины экспорта&r имеют расширенные функции по сравнению с обычной &bШиной экспорта&r."
		""
		"&bШина экспорта по тегам&r экспортирует предметы согласно отфильтрованным тегам."
		""
		"&bШина экспорта модов&r экспортирует предметы из отфильтрованных модов."
		""
		"&bТочная шина экспорта&r экспортирует ровно то количество предметов, которое вы установите, ни больше, ни меньше."
		""
		"&bПороговая шина экспорта&r экспортирует предметы, когда их количество в сети превышает/ниже заданного порога."
	]
	quest.05B2AA73EAEDCCF4.title: "Продвинутые шины экспорта"
	quest.05B31C6305534C62.title: "hidden/collect_pigment/magenta"
	quest.05B38A459AD1E598.title: "hidden/collect_shards/citrine"
	quest.05B7027CC76822A8.title: "hidden/collect_all_crystal_flowers"
	quest.05C2E172AB2AAEF8.title: "hidden/entity_interact/killed_by_monstrosity"
	quest.05D05999E432D3C1.title: "unlocks/enchantments/vanilla_trident"
	quest.05D303B00BF87E84.title: "hidden/collect_cookbooks/poisoners_handbook"
	quest.05DA5787AFFE3035.title: "unlocks/reagents/nectardew_burgeon"
	quest.05E2E87CF3F9A5FB.quest_desc: ["Создаётся из &4Редстоуна&r и &cДизеля&r, используется для &bУлучшения скорости&r."]
	quest.05E2E87CF3F9A5FB.title: "&6Смазка"
	quest.05E7C7E41BA79426.quest_subtitle: "Четверная зарядка"
	quest.060D9F59EB26C7BD.title: "Хлороводород"
	quest.061C09A44A80D7D8.quest_desc: [
		"Сделайте &bАппарат зачарования Викси&r"
		""
		"&l1. Что в нём такого хорошего?&r"
		"Вместо того чтобы раскладывать &9x предметов&r на &bx пьедесталов&r, "
		"почему бы просто не положить эти &9x предметов&r в &bсундук&r или &bбочку&r?"
		""
		"&l2. Как его получить?&r"
		"Нажмите &6ПКМ&r по &bАппарату зачарования&r с &bАмулетом Викси&r в руках."
		"&8(это превратит блок в &bАппарат зачарования Викси&r&8)"
		""
		"&l3. Как это работает?&r"
		"Тот же принцип, что и у &5Амулета Викси&r. Загляните на &bСтраницу 2&r этого квеста :)"
		""
		"{ \"text\": \"НАЖМИ НА МЕНЯ\", \"underlined\": true, \"clickEvent\": { \"action\": \"change_page\", \"value\": \"183EB573F8F1DC8C\" } }"
		""
		""
		"&4ПРИМЕЧАНИЕ&r: радиус действия будет таким же, как у &bКотла Викси&r."
	]
	quest.061C09A44A80D7D8.quest_subtitle: "Время для автокрафта?"
	quest.061C09A44A80D7D8.title: "Аппарат зачарования Викси"
	quest.061EC183CDCBB25B.quest_desc: ["Этот дух будет добывать &bслучайные руды&r. А ещё он немного быстрее."]
	quest.061EC183CDCBB25B.quest_subtitle: "Копаем, копаем яму"
	quest.0622921E67F4DFA5.title: "hidden/collect_shards/amethyst"
	quest.06294216A755E2F2.quest_desc: ["Стержни ифрита используются для создания Свитков огня."]
	quest.0633D2B1E1DB778B.quest_desc: ["Получаемый путём &6переплавки &bПыли истинного кварца&f, &bКремний&f используется в 3 различных процессорах, которые вам понадобятся для дальнейшего продвижения."]
	quest.0633D2B1E1DB778B.title: "Кремний"
	quest.063C55683B4163AF.title: "triggers/hints/shimmerstone_page1"
	quest.064235CAA1FBF2BB.title: "mod_integration/the_bumblezone/white_continuity"
	quest.06573610058AE660.title: "Красный светящийся тростник"
	quest.066402982AEF9728.title: "triggers/hints/azurite_page0"
	quest.068FF8BF07CAB1C3.title: "unlocks/colored_saplings/purple_sapling"
	quest.069382B7A2FC7D35.quest_desc: [
		"Будет &6кальцинироваться&r и &cтерять&r эффективность со временем вплоть до минимальных &e33%&r, если не использовать &bДистиллированную воду&r. "
		""
		"Использование &bТопора&r на &bБойлере&r сбросит его кальцинацию."
	]
	quest.069382B7A2FC7D35.quest_subtitle: "Использует солнечную энергию вместо ископаемого топлива."
	quest.0696635896D223CA.quest_desc: ["Посох Седобородого сделает именно это: подарит вам седую бороду... Шутка. Этот посох поможет вам восстанавливать ману, а также усилит мощь ваших свитков. Это один из самых простых в создании посохов."]
	quest.06C4D99A90DF7711.quest_desc: ["&bСовершенная фабрика инъекций&r позволяет выполнять до &a9&r рецептов инъекций одновременно."]
	quest.06C4D99A90DF7711.title: "Совершенная фабрика инъекций"
	quest.06D66E791A9939DD.quest_desc: ["Постройте &bЗарядник&r и подайте на него энергию с помощью &bВибрационной камеры&r или генераторов из других модов."]
	quest.06D66E791A9939DD.quest_subtitle: "Обеспечивает способ зарядки поддерживаемых инструментов через ME Сеть"
	quest.06D66E791A9939DD.title: "Зарядник"
	quest.06E3AE334E940D6E.title: "hidden/collect_primordial_torch"
	quest.06F1E4885CE3C0C9.quest_desc: ["&bЧистый пергамент&r можно использовать в &bСтоле писца&r, чтобы наносить &dЗаклинания&r на &6Пергамент&r."]
	quest.06F3E3F11AD94BCB.title: "unlocks/head_fusion/incandescent_recipes"
	quest.0729CB454B970201.quest_desc: [
		"  Это &bБронзовый бур&r. Он обеспечит вас основными рудами, которые понадобятся для дальнейшего развития."
		""
		"  Проверьте рецепты в &6EMI&r и учтите, что бур имеет шанс сломаться, поэтому не создавайте только один."
	]
	quest.0729CB454B970201.title: "Бронзовый бур"
	quest.0759B7F600186AEE.title: "unlocks/reagents/aether_vestiges"
	quest.07681F1014BDE3EC.title: "unlocks/enchantments/inventory_insertion"
	quest.07701C64A0D9692D.title: "unlocks/head_fusion/nightdew_recipes"
	quest.077658D04D0D4AB3.quest_desc: [
		"&bРезервуар нашатыря&r должен быть &6установлен под&r &bНакопителем нашатыря&r. Работая вместе, эти два устройства будут создавать &dРастворитель нашатыря&r из &9Воды&r."
		""
		"Если вы хотите получать растворитель &aбыстрее&r, вы можете &6снабжать&r Накопитель &bКристаллами нашатыря&r, что значительно ускорит процесс."
	]
	quest.077658D04D0D4AB3.quest_subtitle: "Он ядовит?"
	quest.077658D04D0D4AB3.title: "Накопитель нашатыря"
	quest.07821D28021BB440.quest_desc: ["&6Разрушает&r &bблоки,&r и этим всё сказано."]
	quest.07821D28021BB440.quest_subtitle: "Бури, детка, бури!"
	quest.078665CB1B57E34C.title: "unlocks/colored_lamps/light_blue_lamp"
	quest.07A78B338ED8DD51.title: "unlocks/food/suspicious_brew"
	quest.07C2255AD8FB16D5.title: "unlocks/enchantments/vanilla_water"
	quest.07CDA4A349A19C92.title: "unlocks/weather/clear"
	quest.07D88A0ABF82A39A.quest_desc: ["Добывается с &6Животных&f при помощи &bНожа&f."]
	quest.07D88A0ABF82A39A.quest_subtitle: "Идеальный материал для свечей"
	quest.07EA93F12235A081.title: "unlocks/reagents/midnight_chip"
	quest.07F1FA5EF3E6A7F3.quest_desc: [
		"Эту &3субстанцию&r можно &6перерабатывать&r на &bТермопневматическом перерабатывающем заводе&r для &6производства&r &bКеросина&r или, добавив &4Редстоун, Смазки&r. "
		""
		"Она служит &aнеплохим&r &7жидким топливом&r, и её также можно &6залить&r в &8Печь&r."
	]
	quest.07F1FA5EF3E6A7F3.title: "&cДизель"
	quest.07FE9074247583EE.quest_desc: [
		"  Возможно, вы заметили, что я сказал «обычно», говоря о взаимодействии с контроллером. Это означает, что предметы и &6жидкости не могут подаваться или извлекаться из контроллера&r, но информация — может; в смысле статистики. Заглянув в контроллер, вы увидите несколько вещей: Правильность формы, Статус, Прогресс, Базу рецепта и Текущий рецепт."
		""
		"  Валидация формы сообщит вам, &6правильно ли построен многоблочный механизм или нет&r. Она не скажет, если вам не хватает люков или их слишком много на механизме, так что вам придется решать это самостоятельно. Имейте в виду, что многоблочные структуры &oмогут&r делить блоки друг с другом, при условии, что эти пересекающиеся блоки НЕ содержат люков."
		""
		"  Статус покажет вам текущее состояние многоблочного механизма. Простаивает ли он или активен."
		""
		"  Прогресс покажет выполнение работы, медленно набирая проценты до 100%. В зависимости от скорости процесса проценты будут расти быстрее."
		""
		"  База рецепта показывает &6базовое потребление энергии/пара рецептом&r. В зависимости от того, что вы делаете, механизм использует минимальное количество энергии/пара, но может использовать и больше, чтобы ускорить процесс. На паровых механизмах этого не происходит, поэтому я не буду сейчас углубляться в это."
		""
		"  Текущий рецепт — это &6текущее количество энергии/пара, которое фактически потребляется&r."
	]
	quest.07FE9074247583EE.title: "Контроллеры многоблочных механизмов"
	quest.0807F0094282C2D5.quest_desc: [
		"&bАндезитовые туннели&r довольно просты: они &6создают&r укрытие для &bКонвейеров&r и предоставляют базовое &6распределение&r предметов, транспортируемых по ним."
		""
		"Вам стоит взглянуть на &bЛатунные туннели&r для получения полезных расширений &6возможностей&r туннелей."
	]
	quest.08252B05F3167E13.title: "hidden/collect_dragonbone_chunk"
	quest.082CF9D15D1BD85B.title: "triggers/hints/clover_page0"
	quest.08347C18C790AF15.title: "unlocks/pylons/any_pylon"
	quest.083D10C1F8685235.title: "mod_integration/malum/replenishing"
	quest.084A1CA79C74FCF7.title: "endgame/find_forsaken_cathedral"
	quest.085722AED332C5DE.title: "unlocks/equipment/lucky_pickaxe"
	quest.0864AB51C373BBBF.title: "unlocks/colored_saplings/orange_sapling"
	quest.0872CF647A181611.title: "unlocks/trinkets/neat_ring"
	quest.087A4AA3C32C388E.title: "triggers/hints/midnight_chip_page1"
	quest.0888176AF1BEA68D.quest_subtitle: "Let them Make Cake!"
	quest.088E87F861406342.quest_desc: ["Используйте её, чтобы &6заполнить&r свой ров, &6осушить&r болото, &6перекачивать&r &9воду&r или &bлаву&r без ограничений."]
	quest.0897CCAC72E82C5B.quest_desc: [
		"&oМод Powah! полностью посвящён генерации, хранению и передаче энергии"
		"&8*Но не для Modern Industrialization"
	]
	quest.0897CCAC72E82C5B.quest_subtitle: "Нужно БОЛЬШЕ ЭНЕРГИИ, да?"
	quest.0897CCAC72E82C5B.title: "&4Добро пожаловать в Powah!!!"
	quest.08A2F489A73BE55B.quest_desc: ["&bСовершенная фабрика обогащения&r может выполнять до &a9&r рецептов одновременно и оснащена такой же функцией \"&eАвтосортировки&r\"."]
	quest.08A2F489A73BE55B.title: "Совершенная фабрика обогащения"
	quest.08B17C05B2111477.quest_desc: [
		"  Поздравляю!"
		""
		"  Теперь вы &6разблокировали&r &oчетвёртый&r и &oпоследний&r тир &bпредметов&r и &bблоков&r мода &lJust Dire Things (JDT)&r."
		""
		"  &bИнструменты&r &6работают мгновенно&r, &bброня&r даёт вам &6способности&r, достойные &oСупермена&r, а &bжезл&r может &6разрывать временные дыры&r в мире. "
		""
		"  Каждый, кто увидит вас в экипировке &lJDT&r высшего тира, поймёт, что вы прошли всё... &2Обычный мир,&r &4Незер&r, &3Энд&r и &9Мрачные глубины&r."
		""
		"{image:justdirethings:item/eclipsealloy_ingot width:100 height:100 align:center fit:true}"
	]
	quest.08B17C05B2111477.quest_subtitle: "Тир 4: Разблокирован"
	quest.08BE35FB8E58C4B5.quest_desc: [
		"&bБазовая фабрика лесопилок&r может выполнять до &a3&r процессов распиловки одновременно. "
		""
		"Слева есть кнопка под названием \"&eАвтосортировка&r\", которая позволяет механизму автоматически распределять входные данные между &a3&r входными слотами."
	]
	quest.08BE35FB8E58C4B5.title: "Базовая фабрика лесопилок"
	quest.08C3213E848BFD0C.quest_desc: [
		"&bМодуль овердрайва&f &6предотвратит&f снижение эффективности &bэлектрического механизма&f, но &6заставит&f механизм постоянно использовать &cполную мощность&f, даже если он ничего не &6обрабатывает&f."
		""
		"Эффективность &oсбросится&r, если рецепт, который &6выполняет&f механизм, изменится."
	]
	quest.08DD0CB24FD0B193.quest_desc: [
		"- &6Точно вращает&r компоненты"
		""
		"- &6Открывает&r и &6закрывает&r &bЖидкостные клапаны&r"
		""
		"- &6Можно красить&r"
	]
	quest.08DD0CB24FD0B193.quest_subtitle: "Но можно ли носить его на затылке?"
	quest.0910D85DD68AFD64.quest_desc: [
		"Транспортировка предметов и зелий."
		"Сборщик ягод истока."
		""
		"- Призыв: нажмите &6ПКМ&r по блоку."
		""
		"- Использование Звёздолапа: используйте &bЖезл Доминиона&r, чтобы задать источник и пункт назначения для Звёздолапа."
		""
		"- Можно привязать к &bКровати из магоцвета&r для отдыха с помощью &bЖезла Доминиона&r."
		""
		"- Требуется ли исток: НЕТ."
	]
	quest.0910D85DD68AFD64.quest_subtitle: "Транспортировка предметов/зелий"
	quest.091830A5A267BF62.title: "unlocks/ampoules/raw_bloodstone_ampoule"
	quest.091C2772ED417247.quest_desc: [
		"  Теперь, когда вы производите энергию в &6тире среднего напряжения (MV)&r, вам нужно убедиться, что ваши механизмы могут принимать эту новую энергию."
		""
		"  Обычно &6кабели даже не подключаются к механизмам, если они не того же тира&r. Но, поместив &bПродвинутый корпус механизма&r (или тиром выше) в слот в правом верхнем углу механизма, вы улучшите механизм до того тира энергии, с которым связан корпус."
		""
		"  По умолчанию электрические механизмы уже находятся на тире &bБазового корпуса механизма&r, и нет необходимости вставлять &bБазовые корпуса механизмов&r в этот слот. Я покажу вам, какие корпуса предназначены для каких тиров энергии."
		""
		"  &6Убедитесь, что вы проверяете, каким механизмам &oдействительно&r&6 нужны улучшения&r, чтобы не тратить ресурсы на механизмы, которым на самом деле не нужен этот дополнительный буст."
	]
	quest.091C2772ED417247.title: "Улучшения корпуса"
	quest.091F017C206F6250.title: "unlocks/food/freigeist"
	quest.0931F12CD1767D8A.title: "unlocks/blocks/pure_pastel_network"
	quest.09336DBAFB15EF52.quest_desc: ["&bПродвинутая механическая труба&r имеет емкость &98,000 мБ&r на каждую секцию трубы и скорость потока при \"&aвытягивании&r\" &91,000 мБ/т&r."]
	quest.09336DBAFB15EF52.title: "Продвинутая механическая труба"
	quest.0953429970AEBCDF.title: "unlocks/food/rabbit_poison"
	quest.095BF2791DB52A57.title: "unlocks/glowblocks/magenta_glowblock"
	quest.097ACA8114CD8DA8.quest_desc: ["&bЭлитная фабрика дробителей&r может выполнять до &a7&r процессов дробления одновременно и оснащена такой же функцией \"&eАвтосортировки&r\"."]
	quest.097ACA8114CD8DA8.title: "Элитная фабрика дробителей"
	quest.098C3858B4FFCE78.quest_desc: ["При использовании &bтермогенератора&f, если вы поставите под него &bпылающий блок&f, он будет генерировать энергию с эффективностью &b280%."]
	quest.098C3858B4FFCE78.quest_subtitle: "На 280% больше энергии"
	quest.098C50324848BA75.title: "unlocks/colored_lamps/yellow_lamp"
	quest.0996DF39F86103AE.title: "hidden/collect_vanilla/echo_shard"
	quest.09A7E1EA28FDC4A2.title: "hidden/collect_aloe"
	quest.09B10C121C7E9023.quest_desc: ["Используется для крафта &bКомпонентов хранения энергии ME&f и других аксессуаров."]
	quest.09FE1275DE91CCFE.title: "unlocks/items/constructors_staff"
	quest.0A1D47CA0DB8907A.title: "unlocks/glowblocks/pink_glowblock"
	quest.0A27CDEFC97B6EEF.title: "unlocks/colored_saplings/lime_sapling"
	quest.0A48423E2375018E.title: "unlocks/items/crafting_tablet"
	quest.0A4865F07E9949E4.title: "hidden/status_effects/effect_prolonging"
	quest.0A4DCF0D6A8101CB.title: "triggers/hints/failing_page0"
	quest.0A5ED413DCB736BE.title: "unlocks/colored_saplings/red_sapling"
	quest.0A67575BAF8596B0.quest_desc: ["Лучше, чем ваши рельсы для моделек поездов: прямые, повороты (двух видов) и уклоны — работают даже через порталы Незера и в непрогруженных чанках!"]
	quest.0A98F73A5B7BA9AE.title: "hidden/collect_milky_resin"
	quest.0AA4A0D42A15D61B.title: "unlocks/blocks/memories_via_mob_head"
	quest.0ABC6D5601DCD95F.quest_desc: ["Можно получить из &6Сундуков с сокровищами&r или при достижении &3Целей&r во время рыбалки."]
	quest.0ABC6D5601DCD95F.quest_subtitle: "Помогите своему путешествию с помощью этих улучшений, предоставляющих различные бонусы."
	quest.0ABC6D5601DCD95F.title: "Крючки и поплавки"
	quest.0AC7D844C55119E1.quest_desc: [
		"  Это не обычный &bГаечный ключ (Monkey Wrench)&r, но вам лучше надеяться, что в будущем вы сможете двигаться так же быстро, как он."
		""
		"  Используя &bГаечный ключ&r, вы можете &6повернуть&r &oпочти&r &bлюбой механизм&r, нажав &6ПКМ&6, и &rподобрать&r&o почти&r любую &bтрубу&r, &bжидкостную&r или &bнет&r."
		""
		"  Вы можете нажать &6Shift+ПКМ&o по &bмеханизму&r, чтобы &6настроить&r &bсторону выхода&r. Когда вы &6держите&r в руках &bГаечный ключ&r, вы можете &6навести курсор&r на любую сторону &bмеханизма&r, и появится своеобразная &bсетка&r. Нажатие &6Shift+ПКМ&o по &bцентральному квадрату&r установит &bсторону выхода&r на ту сторону, на которой находится &bсетка&r. Выполнение этого действия по прямоугольникам &6установит выход&r на сторону под углом &690&r градусов относительно выбранного края, что позволяет &6настраивать&r всё в труднодоступных местах. И, наконец, маленькие &bквадратики&r в каждом углу установят выход на &bпротивоположную&r сторону от сетки."
		""
		"  Помните, вы не можете &6сломать&r механизм с помощью &bГаечного ключа&r — это &6уничтожит&r его, и вы его &6не&r вернёте. Лучше используйте свою верную &bКирку&r."
	]
	quest.0AC7D844C55119E1.title: "Гаечный ключ"
	quest.0ADA007DB5ACA26D.title: "unlocks/enchantments/indestructible"
	quest.0B0AFBA15C0C0282.title: "unlocks/glowblocks/pink_glowblock"
	quest.0B22EC0EDFCA9E9B.title: "unlocks/resources/spectral_shard"
	quest.0B2525D82FDB9406.title: "unlocks/enchantments/resonance_crafting"
	quest.0B26255F779A5096.title: "unlocks/glowblocks/gray_glowblock"
	quest.0B2880C174D39A16.title: "hidden/status_effects/vulnerability"
	quest.0B2FF8169FD3812D.quest_desc: [
		"  &bСтальные люки&r имеют &6вдвое большую емкость по сравнению с бронзовыми люками&r, увеличивая количество слотов инвентаря с 1 до 2, а также повышая максимальное потребление пара многоблочной структурой с 2 EU/t до 4 EU/t. Пока хотя бы один стальной люк ввода жидкости получает пар, вся ваша многоблочная структура улучшается до «стального тира»."
		""
		"  Возможность использования многоблочными механизмами 4 EU/t означает именно то, о чем вы подумали — это удваивает максимальную скорость процессов."
		""
		"  &bСтальной бойлер&r производит вдвое больше пара, чем бронзовый. Это означает, что он выдаст максимум &o16 EU/t&r вместо 8. &bСтальная водяная помпа&r также производит вдвое больше &bВоды&r, чем её бронзовый аналог: максимум 250 мБ &bВоды&r из каждого соседнего источника воды, обеспечивая до 2000 мБ &bВоды&r каждые 5 секунд."
	]
	quest.0B2FF8169FD3812D.quest_subtitle: "Ждёте, пока что-нибудь вылупится?"
	quest.0B2FF8169FD3812D.title: "Стальные люки"
	quest.0B47F7D08B9EF2BE.title: "hidden/collect_fissure_plum"
	quest.0B4D059EDFD90B5B.quest_desc: [
		"Наполните &bТравильный бак&r &2Травильной кислотой&r и поместите туда &7Пустые печатные платы&r, которые были засвечены в &eУФ-камере&r. "
		""
		"Дополнительно вы можете &cнагреть&r бак до температуры выше &c50&r градусов Цельсия, чтобы &eускорить&r процесс травления, однако из-за этого &2Травильная кислота&r будет расходоваться быстрее. "
		""
		"Извлекайте &bНесобранные печатные платы&r с боков бака, а &cБракованные печатные платы&r — сверху или снизу."
	]
	quest.0B4FA0D7AEB3B6AA.title: "milestones/unlock_shooting_stars"
	quest.0B94435972292812.quest_desc: [
		"&bПространственный порт ввода-вывода&f — это ядро &bсистемы пространственной оцифровки&f. Он размещается в вершине, где сходятся все 3 &bграни из пилонов&f. Именно в него вы помещаете &bПространственную ячейку&f и позволяете ей &6захватить постройку или высвободить её&f. На этот же блок необходимо подавать энергию для зарядки системы."
		""
		"Вы также можете взаимодействовать с &bПространственным портом ввода-вывода с помощью воронок&f или других труб, чтобы автоматизировать процесс, если захотите. &6Сигнал редстоуна&f — это всё, что нужно &bПространственному порту ввода-вывода&f для активации. Будьте осторожны!"
	]
	quest.0B94435972292812.title: "Пространственный порт ввода-вывода"
	quest.0B94E87BE3289A8D.title: "hidden/collect_vanilla/nautilus_shell"
	quest.0B98E8AC5CFB0FC2.quest_desc: ["Получается, когда вы позволяете своим &bЭнтропированным друзам &aдозреть&f до &aмаксимальной стадии&f."]
	quest.0BCCFBE8E29DD5E6.title: "hidden/collect_gilded_book"
	quest.0BDF41399223A10A.quest_desc: ["Используя Кузню свитков и Эндер-жемчуг, создайте Эндер-свитки."]
	quest.0BF3E2C6D60A58BB.quest_desc: [
		"Доступ к &aЭмоциям&r можно получить через &6Быстрое меню&r."
		""
		"Клавиша по умолчанию — \"&eB&r\". "
		""
		"Я &3настоятельно рекомендую&r изменить эту клавишу на какую-нибудь другую."
		""
		"Вы можете просмотреть все доступные &aЭмоции&r, зайдя в меню &7Все эмоции&r через кнопку под &6Быстрым меню&r. "
		""
		"Настройте &6Быстрое меню&r, нажав кнопку &7Настроить эмоции&r. "
		""
		"Сначала выберите желаемую &aЭмоцию&r, а затем &cслот&r, в который вы хотите её добавить."
		""
		"&b&lТанцуй!&r"
	]
	quest.0BF3E2C6D60A58BB.quest_subtitle: "Вызываю тебя на танцевальный баттл!"
	quest.0BF3E2C6D60A58BB.title: "&aЭмоции"
	quest.0BF65F02CFC23E07.title: "unlocks/items/everpromise_ribbon_guidebook"
	quest.0C18429AFD83973C.quest_desc: [
		"Обожаю их! С их помощью можно..."
		""
		"- &6Вращать&r близко расположенные, параллельные &bВалы&r* с одинаковым направлением, или"
		""
		"- Повернуть любой из них на &690°&r по отношению к остальным, и..."
		""
		"- &6Удвоить скорость&r, или &6уменьшить вдвое&r с помощью &bПереключателя передач&r и щепотки &bредстоуна&r!"
		""
		"(* или &bВентиляторы в корпусе&r и т.д.)"
	]
	quest.0C1C61B4554B38E5.quest_desc: [
		"&bОбъединитель&r позволяет &6соединять предметы&r вместе, например, &dсамоцвет&r и &7камень&r, чтобы получить &8руду&r; &eвоск&r и &cмедь&r, чтобы защитить её от окисления; смешивать красители и многое другое. "
		""
		"Проверьте &dEMI&r, чтобы узнать, что ещё можно с ним сделать."
	]
	quest.0C1C61B4554B38E5.title: "Объединитель"
	quest.0C1DF2F58823BCBE.title: "unlocks/reagents/bismuth_flake"
	quest.0C2901AD0878C5B4.title: "unlocks/upgrades/upgrade_efficiency2"
	quest.0C2DFB4A8DF29B1D.quest_desc: [
		"&l1. Информация&r"
		"- Если &6улучшить&r ритуал предметом, он вернёт &bПутеводитель&r (похожий на компас)"
		"&8+ Он будет указывать на структуру и показывать расстояние до неё."
		"&8+ Он ищет &6ближайшую &8структуру от &bместа проведения ритуала&r&8."
		""
		"&l2. Некоторые примечательные структуры&r"
		"- &bВанильные структуры&r"
		"&8+ Крепость Незера."
		"&8+ Бастион."
		"&8+ Подводная крепость."
		"&8+ Древний город."
		"&8+ Город Энда."
		""
		"- &bСтруктуры Ars&r"
		"&8+ Логово вилдена"
		"&8+ Тайная библиотека."
	]
	quest.0C2DFB4A8DF29B1D.quest_subtitle: "Компас для структур"
	quest.0C34B97F1EA88415.quest_subtitle: "Способ легко телепортироваться из пещер."
	quest.0C37E9D8A7823264.quest_desc: ["Трость Артефактора помогает ходить всем вам, старикам... Снова шутка. Этот посох даст сокращение времени перезарядки и времени каста, а также усилит мощь ваших заклинаний. Он немного дороже Посоха Седобородого, но того стоит для применения более мощных заклинаний (сделайте эти посохи отдельной механикой)."]
	quest.0C4BBD3E4D3D4FFE.title: "unlocks/food/spiked_mullet_wine"
	quest.0C4D725BD1DB481C.title: "milestones/unlock_fourth_potion_workshop_reagent_slot"
	quest.0C53E42899D3D271.quest_desc: ["Простое &6управление&r приводными &bВалами&r или &bШестернями&r с помощью &bредстоуна&r."]
	quest.0C5C7EBD63963873.title: "milestones/reveal_colored_trees_k"
	quest.0C625368977D98FA.title: "unlocks/redstone/block_placer"
	quest.0C6D0B1C1AF75292.quest_desc: [
		"  Уинстон? Вы чертовски правы."
		""
		"  &bХимический реактор&r можно использовать как закрытый механизм для использования &6химической реакции между веществами&r в этом мире для создания новых вещей."
		""
		"  &bХимический реактор&r будет стимулировать эти реакции и держать их в изоляции, так что вы не пострадаете и не заболеете от выделяющихся паров, жидкостей или твердых частиц."
		""
		"  Ну, что скажешь? Давай варить."
	]
	quest.0C6D0B1C1AF75292.quest_subtitle: "Скажи моё имя!"
	quest.0C6D0B1C1AF75292.title: "Химический реактор"
	quest.0C91DF887A33A8E6.quest_desc: [
		"&oПомните, я говорил, что духи могут добывать для вас руду?&r"
		""
		"Это устройство — портал в другое измерение, в которое могут войти только ваши духи. &6Предоставьте&r ему &bдуха-шахтёра&r, и он будет приносить &bРуду&r и &bдругие блоки&r, сохраняя их в своём инвентаре."
		""
		"Блок можно &6отключать&r &bредстоуном,&r а &bпрочность&r лампы можно &6измерить&r с помощью &bкомпаратора.&r С помощью простой схемы вы можете остановить работу шахтёрских ламп до того, как они сломаются."
	]
	quest.0C91DF887A33A8E6.quest_subtitle: "Это не добыча из пустоты; это добыча в карманном измерении"
	quest.0C9E727278D1F4AA.title: "unlocks/pylons/moonstone_pylon"
	quest.0CBBECBBB20E8C62.title: "hidden/collect_enchanted_star_candy"
	quest.0CC32C98A4D260DA.title: "unlocks/colored_lamps/yellow_lamp"
	quest.0CD0B3C97F8D180A.title: "unlocks/items/everpromise_ribbon_recipe"
	quest.0CE23EC64E1F4D8D.title: "unlocks/food/suspicious_brew"
	quest.0CF205A7783A284C.title: "triggers/hints/fading_page1"
	quest.0CFD3E65D3B73EC0.title: "triggers/hints/preservation_ruins_page2"
	quest.0D05BCDFF965A063.title: "unlocks/enchantments/vanilla_swift_sneak"
	quest.0D1AFCAD90FAA4F9.quest_desc: ["Этот жезл предварительно настроен на поиск &aОбычного&r материала."]
	quest.0D286B3B99B7D3EE.title: "unlocks/trinkets/ring_of_pursuit"
	quest.0D332DB8D3C3A190.title: "unlocks/glowblocks/blue_glowblock"
	quest.0D44F37BE787CA30.quest_desc: ["Эту &3субстанцию&r можно &6перерабатывать&r на &bТермопневматическом перерабатывающем заводе&r для получения &eСжиженного нефтяного газа (LPG)&r, который является &aотличным&r &7жидким топливом&r, сопоставимым по качеству с &7Очищенным топливом&r из мода &3Thermal Expansion&r. "]
	quest.0D44F37BE787CA30.title: "&6Бензин"
	quest.0D469F2023DB4E84.title: "hidden/status_effects/stiffness"
	quest.0D4D113CBE265612.title: "unlocks/upgrades/upgrade_speed2"
	quest.0D5C81AA57658E51.title: "unlocks/reagents/jadeite_petals"
	quest.0D7D95FD8A09FE35.title: "unlocks/enchantments/vanilla_water_luck"
	quest.0D8988AF02D890EA.quest_subtitle: "Найдите Древнее поле битвы"
	quest.0D8988AF02D890EA.title: "Ходячие мертвецы"
	quest.0DA354D54D288D20.quest_desc: [
		"&bБазовый термопроводник&r используется для передачи &4тепла&r из одного места в другое. "
		""
		"Каждый проводник, добавленный в &cтермодинамическую сеть&r, увеличивает её общую &4теплоёмкость&r на &a1.0&r, хотя вся сеть будет поддерживать проводимость &e5.0&r и теплоизоляцию &c10.0&r"
		""
		"Изоляционные возможности &bТермопроводников&r зависят от &2биома&r. "
		""
		"Если вы находитесь в &cтёплом/жарком&r биоме, эффективность передачи &aвыше&r; если вы в &bхолодном/ледяном&r биоме, эффективность передачи &cниже&r."
	]
	quest.0DA354D54D288D20.title: "Базовый термопроводник"
	quest.0DAE4D6CC951BF54.title: "hidden/discover_weeping_gala"
	quest.0DB39EEB31BB51E3.title: "unlocks/food/rock_candy"
	quest.0DC8081D9EA61411.title: "Киви"
	quest.0DC83D9B8B09C093.quest_desc: [
		"&bСтол изменения&r можно использовать для &6улучшения&r &bброни&r. "
		""
		"&l1. Наложение нитей:&r"
		"- Положите вашу &bброню&r на стол."
		"- Нажмите &6ПКМ&r нужным символом по бумажной части. "
		"- Заберите броню."
		""
		"&l2. Извлечение нитей:&r"
		"- Положите вашу &bброню&r на стол."
		"- Нажмите &6ПКМ&r по бумажной части."
		"- Заберите броню."
	]
	quest.0DDB41027911D935.title: "hidden/collect_paltaeria_gem"
	quest.0DDE4F5B0FE265B0.quest_desc: [
		"&bТрубы высокого давления&r передают &7воздух&r между &bКомпрессорами&r и &bМеханизмами&r, их можно &2замаскировать&r, чтобы они сливались с &aокружением&r. "
		""
		"Кроме того, к этим &bТрубам&r можно &6прикрепить&r &bМодули для труб&r, чтобы обеспечить &aдополнительные функции&r или &eвозможности&r."
	]
	quest.0E20737816537599.title: "triggers/hints/radiating_ender_page1"
	quest.0E30CFA6C5B58BEA.quest_desc: ["Этот &bЧан&r позволяет вам преобразовывать вашу &bАлхимическую селитру&r из одного тира в другой."]
	quest.0E30CFA6C5B58BEA.quest_subtitle: "Улучшения?"
	quest.0E352E2B17084DAE.quest_desc: ["&bПродвинутая фабрика лесопилок&r может выполнять до &a5&r процессов распиловки одновременно и оснащена такой же функцией \"&eАвтосортировки&r\"."]
	quest.0E352E2B17084DAE.title: "Продвинутая фабрика лесопилок"
	quest.0E3A8954B2AAF9F7.quest_desc: [
		"Используйте &bРитуальную жаровню&r, чтобы призвать &4Химеру вилденов&r, а затем победите её."
		""
		"Этот предмет позволит вам создать &bКнигу заклинаний&r высшего тира."
	]
	quest.0E50E568DFA078D5.quest_desc: [
		"  Развитие в &oJust Dire Things&r связано с четырьмя видами &o&l&bслизи&r."
