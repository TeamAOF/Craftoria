	quest.0107F5FF7CB2DC78.title: "milestones/reveal_storm_stones"
	quest.010963EDF54301CD.title: "hidden/collect_shale_clay"
	quest.010F3BEDCA334DCB.quest_desc: [
		"&bУлучшение разрушения&f &6уничтожает&f блоки (&cкроме&f &bсущностей блоков (block entities)&f) с той стороны, на которую вы смотрите. Они полностью &4исчезнут&f, хотя вы можете &6отменить&f ошибку с помощью функции отмены."
		""
		"Используйте &bСтол кузнеца&f, чтобы применить это улучшение к вашей палке, используя &cблок редстоуна&f в качестве материала."
	]
	quest.0119F518ACD8568D.quest_subtitle: "+Управление редстоуном"
	quest.011E9553CDCAE218.quest_desc: ["Учетверяем вместимость хранилища?"]
	quest.011E9553CDCAE218.title: "Компонент хранения 4k"
	quest.012B064DED21DCD3.quest_desc: [
		"&bСовершенная фабрика наполнителей&r может выполнять до &a9&r процессов наполнения одновременно и оснащена такой же функцией \"&6Автосортировки&r\". "
		""
		"&bСовершенная фабрика наполнителей&r также может вмещать до &18,960 мБ&r материала для наполнения."
	]
	quest.0145A878C472548C.quest_desc: ["Этот дух берёт на себя &6выращивание&r и рубку &bдеревьев&r. Он даже пытается сажать их заново!"]
	quest.0145A878C472548C.quest_subtitle: "Есть дерево?"
	quest.0145A878C472548C.title: "Ритуал: Призыв фолиота-лесоруба"
	quest.017309CDB87F2A1E.quest_desc: [
		"Сам по себе он ничего не делает... но является ключевым ингредиентом для создания множества других желанных вещей."
		""
		"А ещё, возможно, это будет первая вещь, для производства которой вы захотите построить механизм."
	]
	quest.0177FDF039717D04.title: "unlocks/food/triple_meat_pot_pie"
	quest.0190B84440390307.title: "milestones/reveal_colored_trees_k"
	quest.0190F6A2514D43A0.title: "unlocks/pylons/topaz_pylon"
	quest.01A6F161BE896642.title: "unlocks/blocks/moonstone_semi_permeable_glass"
	quest.01E8A006742F7A00.quest_desc: [
		"По умолчанию объем хранилища у Привода не самый большой."
		""
		"Вы можете решить эту проблему, используя &bСтабилизаторы&r. Они дополнительно &6стабилизируют&r связь Привода с измерением хранения, позволяя ему &6вмещать всё больше&r и больше."
	]
	quest.01E8A006742F7A00.quest_subtitle: "Этого всё ещё недостаточно"
	quest.0202CCA9DCC07A16.title: "hidden/status_effects/toughness"
	quest.02043A7B0B8D15FD.title: "unlocks/colored_lamps/lime_lamp"
	quest.0214195602EC56F9.title: "hidden/visit_dd_biomes/howling_spires"
	quest.02272D430F08B1DC.quest_desc: [
		"  Теперь вы можете создать большой резервуар! Это многоблочный резервуар, который может вмещать 64,000 мБ &oна каждый&r блок общего объёма, включая блоки воздуха и твёрдые блоки."
		""
		"  Когда вы установите Большой резервуар, откройте его интерфейс и обратите внимание на верхний левый угол. Там можно выбрать желаемый размер. "
		""
		"  Сделав выбор, возьмите в руки свой верный гаечный ключ, и голограмма покажет вам, куда ставить блоки."
		""
		"  Также используйте Люк большого резервуара. Он работает так же, как и другие люки, за исключением того, что является только точкой доступа к резервуару. Он будет принимать и отдавать жидкости через любые прикреплённые к нему люки."
	]
	quest.023A420F24C515EB.quest_desc: ["&8Укреплённая&r версия &bБазовой трубы высокого давления&r. Их можно &2замаскировать&r, а также добавлять &bМодули для труб&r, чтобы обеспечить &eдополнительный функционал&r."]
	quest.026C88446512DDB8.quest_subtitle: "Может выполнять рецепты &eКоксовой печи&r партиями."
	quest.027D62E83A7A81B4.title: "unlocks/enchantments/improved_critical"
