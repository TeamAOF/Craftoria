	quest.03C11AD9CB224597.title: "unlocks/blocks/item_roundel"
	quest.03C405F59A8FA1D0.title: "unlocks/blocks/compacting_chest"
	quest.03CF6D6277D93A4A.quest_desc: [
		"&bИзмерительная пипетка&r — полезный инструмент для &6перемещения&r до &a16&r вёдер &7жидкости&r за раз напрямую из &9инвентаря&r. "
		""
		"В будущем это поможет вам правильно &6настраивать&r механизмы. "
		""
		"Нажмите &6ПКМ&r, чтобы вылить &7жидкость&r, и &6ЛКМ&r, чтобы собрать её."
	]
	quest.03CF6D6277D93A4A.title: "Измерительная пипетка"
	quest.03E0ADE2191CC3FB.quest_desc: ["Каждая &bПродвинутая индукционная ячейка&r, добавленная в вашу матрицу, увеличивает объём хранения энергии на &e25.6 GFE&r."]
