	quest.5619683321410B74.title: "Большой пространственный компонент"
	quest.5643738FABBFB6CE.title: "unlocks/trinkets/any_base_trinket"
	quest.5663A6C559490A29.quest_desc: ["Нажмите &6ПКМ&f &bжемчужиной ариэля (ariel pearl)&f по &bзомби&f или &bкадавру (husk)&f, и дело сделано."]
